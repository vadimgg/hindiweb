---
/**
 * Sentences tab content — sentence cards grid, empty states.
 *
 * Responsible for: rendering the sentences tab with chapter-grouped sentence cards,
 * empty state, and no-results placeholder.
 *
 * Dependencies: SentenceList.astro, types.ts (SentenceChapter).
 */
// Responsible for: Sentences tab content — sentence cards grid, empty states
import SentenceList from '../SentenceList.astro';
import type { SentenceChapter } from '../../utils/types';

interface DateGroup { date: string; label: string; items: { w: any; i: number }[]; }
interface Props {
  allSentences: any[];
  sentencesByDate: DateGroup[];
  sentenceChapters: SentenceChapter[];
}
const { allSentences, sentenceChapters } = Astro.props;
---

<div id="tab-sentences" class="hidden px-5 sm:px-8 py-8 max-w-3xl mx-auto lg:mx-0 lg:max-w-2xl xl:max-w-3xl">
  {allSentences.length > 0 ? (
    <div class="space-y-5" id="sentences-container">
      <SentenceList sentenceChapters={sentenceChapters} />
    </div>
  ) : (
    <div class="py-24 text-center">
      <p class="text-zinc-600 text-sm mb-2">No sentences loaded yet.</p>
      <p class="text-zinc-700 text-xs">Drop <code class="text-zinc-600">*.json</code> files into <code class="text-zinc-600">vocab/sentences/</code>.</p>
    </div>
  )}
  <div id="sentences-no-results" class="hidden py-20 text-center">
    <p class="text-zinc-600 text-sm">No sentences match your search.</p>
  </div>
</div>
