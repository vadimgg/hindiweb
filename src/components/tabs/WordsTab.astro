---
/**
 * Words tab content — meta line, word cards grid, empty state, footer.
 *
 * Responsible for: Words tab content — meta line, word cards grid, empty state, footer.
 *
 * Dependencies: WordCard.astro.
 */
// Responsible for: Words tab content — meta line, word cards grid, empty state, footer
import WordCard from '../WordCard.astro';

interface Props {
  allWords: any[];
  vocabFilesCount: number;
}
const { allWords, vocabFilesCount } = Astro.props;
---

<div id="tab-words" class="px-5 sm:px-8 py-8 max-w-3xl mx-auto lg:mx-0 lg:max-w-2xl xl:max-w-3xl">
  <p class="hidden lg:block text-xs text-zinc-600 mb-8" id="words-meta">
    {allWords.length} {allWords.length === 1 ? 'word' : 'words'} &middot; {vocabFilesCount} {vocabFilesCount === 1 ? 'file' : 'files'}
  </p>
  <div class="space-y-5" id="cards-container">
    {allWords.map((word, i) => (
      <div data-word-card={i}>
        <WordCard
          hindi={word.hindi}
          romanisation={word.romanisation}
          english={word.english}
          date_added={word.date_added}
          english_usage={word.english_usage}
          forms={word.forms}
          pos={word.pos}
          gender={word.gender}
          transitivity={word.transitivity}
          syllables={word.syllables}
          collocations={word.collocations}
          usage_notes={word.usage_notes}
          related_words={word.related_words}
          sound_alikes={word.sound_alikes}
          etymology_journey={word.etymology_journey}
          origin_note={word.origin_note}
          index={i}
        />
      </div>
    ))}
  </div>
  <div id="words-no-results" class="hidden py-20 text-center">
    <p class="text-zinc-600 text-sm">No words match your search.</p>
  </div>
  <footer class="mt-20 text-xs text-zinc-700">Drop <code class="text-zinc-600">*.json</code> files into <code class="text-zinc-600">vocab/words/</code> to add words.</footer>
</div>
