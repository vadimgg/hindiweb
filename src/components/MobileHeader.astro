---
// Responsible for: mobile-only page header with title and search input (hidden on lg+)
---
<div class="lg:hidden px-5 pt-10 pb-6">
  <p class="font-title text-[10px] font-semibold uppercase tracking-[0.2em] text-zinc-600 mb-1">Study companion</p>
  <h1 class="font-title text-3xl font-semibold text-zinc-100 mb-5">Hindi Vocabulary</h1>
  <div class="relative">
    <input data-search-input type="text" autocomplete="off" spellcheck="false" placeholder="Search words…"
      class="w-full bg-slate-800/60 border border-slate-700/60 rounded-xl pl-4 pr-9 py-2.5 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-slate-500 transition-colors" />
    <button data-search-clear class="absolute right-3 top-1/2 -translate-y-1/2 text-zinc-600 hover:text-zinc-300 transition-colors hidden" aria-label="Clear search">✕</button>
  </div>
</div>
