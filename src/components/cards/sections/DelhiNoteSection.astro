---
/**
 * WordCard section: Delhi Usage note.
 *
 * Responsible for: rendering a Delhi-specific usage callout as an expandable
 * section inside a word card.
 *
 * No dependencies on other project modules.
 */
// Responsible for: Delhi Usage expandable section inside a word card

interface Props {
  delhiNote: string;
}
const { delhiNote } = Astro.props;
---

{delhiNote && (
  <details class="group/det border-l-2 border-l-transparent hover:border-l-amber-400/20 hover:bg-white/[0.018] transition-colors">
    <summary class="flex items-center justify-between px-4 sm:px-6 py-3 sm:py-4 cursor-pointer list-none select-none transition-colors">
      <span class="font-title text-xs sm:text-sm font-bold tracking-[0.2em] uppercase text-slate-400 group-open/det:text-slate-200 group-hover/det:text-slate-400 transition-colors">Delhi Usage</span>
      <span class="text-slate-600 group-open/det:rotate-180 transition-transform duration-200 text-xs">▾</span>
    </summary>
    <div class="px-4 sm:px-6 pb-4 pt-1">
      <p
        class="text-[15px] text-slate-300 leading-relaxed bg-slate-800/60 rounded-r-lg px-4 py-3.5 border border-slate-700/40 border-l-[3px] border-l-amber-500/35"
      >
        {delhiNote}
      </p>
    </div>
  </details>
)}
