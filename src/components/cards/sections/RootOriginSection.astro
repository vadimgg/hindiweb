---
// Responsible for: Root & Origin and Etymology Story expandable sections inside a word card
import { highlight } from '../../../utils/highlight';
import type { RootBreakdown, RootPart, RootRoot, RootEvolutionStep } from '../../../utils/types';

interface Props {
  in_hindi_via?: string;
  root_parts: RootPart[];
  root_breakdown?: RootBreakdown;
  root_notes: string[];
  root_and_origin_explanation: string[];
  etymology_story?: string | string[];
}
const { in_hindi_via, root_parts, root_breakdown, root_notes, root_and_origin_explanation, etymology_story } = Astro.props;

const rb = root_breakdown ?? {};
const rootIsObject = rb.root && typeof rb.root === 'object';
const rootIsString = rb.root && typeof rb.root === 'string';
const evolutionIsArray = Array.isArray(rb.evolution);
const evolutionIsString = rb.evolution && typeof rb.evolution === 'string';
const etymologyLines: string[] = Array.isArray(etymology_story)
  ? etymology_story
  : etymology_story ? [etymology_story] : [];
---

<details class="group/det">
  <summary class="flex items-center justify-between px-4 sm:px-6 py-3 sm:py-4 cursor-pointer list-none select-none hover:bg-slate-800/30 transition-colors">
    <span class="font-title text-xs sm:text-sm font-medium tracking-wider uppercase text-slate-400 group-open/det:text-slate-200 transition-colors">Root &amp; Origin</span>
    <span class="text-slate-600 group-open/det:rotate-180 transition-transform duration-200 text-xs">▾</span>
  </summary>
  <div class="border-l-2 border-blue-500/40 ml-4 sm:ml-6 mb-4 px-4 sm:px-5 py-3 sm:py-4 space-y-3">
    {in_hindi_via && <p class="text-[13px] text-blue-300/70 italic">{in_hindi_via}</p>}
    {root_parts.length > 0 && (
      <div class="space-y-2">
        {root_parts.map((part) => (
          <div class="flex items-baseline gap-2">
            <span class="word-hindi text-base shrink-0" lang="hi">{part.script}</span>
            <span class="word-roman text-sm shrink-0">{part.element}</span>
            <span class="text-slate-400 text-sm">— {part.meaning}</span>
          </div>
        ))}
      </div>
    )}
    {rootIsObject && (
      <div class="flex flex-wrap items-baseline gap-x-2 gap-y-0.5">
        <span class="word-hindi text-base font-medium" lang="hi">{(rb.root as RootRoot).word}</span>
        <span class="word-roman text-sm">{(rb.root as RootRoot).romanisation}</span>
        <span class="text-slate-400 text-sm">— {(rb.root as RootRoot).meaning}</span>
        <span class="text-slate-600 text-xs">({(rb.root as RootRoot).language})</span>
      </div>
    )}
    {rootIsString && (
      <p class="text-slate-100 text-base font-medium leading-relaxed" set:html={highlight(rb.root as string)} />
    )}
    {evolutionIsArray && (rb.evolution as RootEvolutionStep[]).length > 0 && (
      <p class="text-[13px] text-teal-300/70 font-mono tracking-wide leading-relaxed">
        {(rb.evolution as RootEvolutionStep[]).map((s, i) => (
          <>{i > 0 && <span class="text-slate-700 mx-1">→</span>}<span>{s.stage}: <span class="text-teal-200/90">{s.form}</span></span></>
        ))}
      </p>
    )}
    {evolutionIsString && (
      <p class="text-[14px] text-teal-300/70 font-mono tracking-wide leading-relaxed" set:html={highlight(rb.evolution as string)} />
    )}
    {rb.logic && (
      <p class="text-[15px] text-slate-400 italic leading-relaxed" set:html={highlight(rb.logic)} />
    )}
    {root_notes.map((line) => (
      <p class="text-[15px] text-slate-300 leading-relaxed" set:html={highlight(line)} />
    ))}
    {root_and_origin_explanation.map((line, i) => (
      <p class:list={['leading-relaxed', i === 0 ? 'text-slate-100 text-base font-medium' : 'text-[15px] text-slate-300']}
        set:html={highlight(line)} />
    ))}
  </div>
</details>

{etymologyLines.length > 0 && (
  <details class="group/det">
    <summary class="flex items-center justify-between px-4 sm:px-6 py-3 sm:py-4 cursor-pointer list-none select-none hover:bg-slate-800/30 transition-colors">
      <span class="font-title text-xs sm:text-sm font-medium tracking-wider uppercase text-slate-400 group-open/det:text-slate-200 transition-colors">Etymology Story</span>
      <span class="text-slate-600 group-open/det:rotate-180 transition-transform duration-200 text-xs">▾</span>
    </summary>
    <div class="border-l-2 border-amber-500/50 ml-4 sm:ml-6 mb-4 px-4 sm:px-5 py-3 sm:py-4 space-y-2">
      {etymologyLines.map((para) => (
        <p class="text-base text-slate-200 leading-relaxed" set:html={highlight(para)} />
      ))}
    </div>
  </details>
)}
