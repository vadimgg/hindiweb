---
// Responsible for: Memory Hook expandable section inside a word card
import { langColor, cap } from '../../../utils/cardHelpers';
import { highlight } from '../../../utils/highlight';

interface Props {
  hookPrimary: string;
  hookByLanguage: [string, string][];
}
const { hookPrimary, hookByLanguage } = Astro.props;
---

<details class="group/det">
  <summary class="flex items-center justify-between px-7 py-4 cursor-pointer list-none select-none hover:bg-slate-800/30 transition-colors">
    <span class="font-title text-sm font-medium tracking-wider uppercase text-slate-400 group-open/det:text-slate-200 transition-colors">Memory Hook</span>
    <span class="text-slate-600 group-open/det:rotate-180 transition-transform duration-200 text-xs">▾</span>
  </summary>
  <div class="px-7 pb-6 pt-3 space-y-2.5">
    {hookPrimary && (
      <div class="bg-slate-950/80 border-l-2 border-violet-500/60 rounded-r-xl px-5 py-4">
        <p class="text-[15px] text-slate-200 leading-relaxed" set:html={highlight(hookPrimary)} />
      </div>
    )}
    {hookByLanguage.map(([lang, text]) => (
      <div class="bg-slate-950/70 border-l-2 border-violet-400/30 rounded-r-xl px-5 py-3">
        <span class:list={['text-[11px] font-title font-semibold uppercase tracking-wider mb-1.5 inline-block', langColor(cap(lang))]}>
          {cap(lang)}
        </span>
        <p class="text-[14px] text-slate-300 leading-relaxed" set:html={highlight(text)} />
      </div>
    ))}
  </div>
</details>
