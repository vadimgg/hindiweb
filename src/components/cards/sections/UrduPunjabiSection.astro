---
// Responsible for: Urdu & Punjabi expandable section inside a word card
import { langColor } from '../../../utils/cardHelpers';
import { highlight } from '../../../utils/highlight';
import type { UrduPunjabi } from '../../../utils/types';

interface Props { urdu_punjabi: UrduPunjabi; }
const { urdu_punjabi } = Astro.props;
---

<details class="group/det">
  <summary class="flex items-center justify-between px-7 py-4 cursor-pointer list-none select-none hover:bg-slate-800/30 transition-colors">
    <span class="font-title text-sm font-medium tracking-wider uppercase text-slate-400 group-open/det:text-slate-200 transition-colors">Urdu &amp; Punjabi</span>
    <span class="text-slate-600 group-open/det:rotate-180 transition-transform duration-200 text-xs">▾</span>
  </summary>
  <div class="px-7 pb-6 pt-3">
    <div class="bg-slate-950/70 border-l-2 border-orange-500/40 rounded-r-xl px-5 py-4 space-y-4">
      {urdu_punjabi.urdu && (
        <div>
          <div class="flex items-center gap-2 flex-wrap mb-1.5">
            <span class:list={['text-[11px] font-title font-semibold uppercase tracking-wide', langColor('Urdu')]}>Urdu</span>
            {urdu_punjabi.urdu.script && (
              <span class="text-xl text-amber-300/90 font-serif leading-none" dir="rtl" lang="ur">{urdu_punjabi.urdu.script}</span>
            )}
            {urdu_punjabi.urdu.romanisation && (
              <span class="word-roman text-sm">({urdu_punjabi.urdu.romanisation})</span>
            )}
          </div>
          {urdu_punjabi.urdu.note && (
            <p class="text-[15px] text-slate-300 leading-relaxed" set:html={highlight(urdu_punjabi.urdu.note)} />
          )}
        </div>
      )}
      {urdu_punjabi.punjabi && (
        <div>
          <div class="flex items-center gap-2 flex-wrap mb-1.5">
            <span class:list={['text-[11px] font-title font-semibold uppercase tracking-wide', langColor('Punjabi')]}>Punjabi</span>
            {urdu_punjabi.punjabi.script && (
              <span class="text-xl text-yellow-300/90 font-serif leading-none" lang="pa">{urdu_punjabi.punjabi.script}</span>
            )}
            {urdu_punjabi.punjabi.romanisation && (
              <span class="word-roman text-sm">({urdu_punjabi.punjabi.romanisation})</span>
            )}
          </div>
          {urdu_punjabi.punjabi.note && (
            <p class="text-[15px] text-slate-300 leading-relaxed" set:html={highlight(urdu_punjabi.punjabi.note)} />
          )}
        </div>
      )}
    </div>
  </div>
</details>
