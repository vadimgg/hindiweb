---
// Responsible for: Examples expandable section inside a word card
// IMPORTANT: data-example-card={index} must be preserved — tooltip.js uses it to annotate vocab hints
import { registerStyle } from '../../../utils/cardHelpers';
import { highlight } from '../../../utils/highlight';
import type { Example } from '../../../utils/types';

interface Props {
  examples: Example[];
  index: number;
}
const { examples, index } = Astro.props;
---

<details class="group/det">
  <summary class="flex items-center justify-between px-4 sm:px-6 py-3 sm:py-4 cursor-pointer list-none select-none hover:bg-slate-800/30 transition-colors">
    <span class="font-title text-xs sm:text-sm font-medium tracking-wider uppercase text-slate-400 group-open/det:text-slate-200 transition-colors">Examples</span>
    <span class="text-slate-600 group-open/det:rotate-180 transition-transform duration-200 text-xs">▾</span>
  </summary>
  <div class="px-4 sm:px-6 pb-4 space-y-3">
    {examples.map((ex) => (
      <div class="bg-slate-800/40 rounded-xl p-3 sm:p-4 border border-slate-700/30" data-example-card={index}>
        <div class="flex items-start justify-between gap-2 mb-1">
          <p class="word-hindi text-lg font-medium leading-snug" lang="hi">{ex.hindi}</p>
          {ex.register && (
            <span class:list={['shrink-0 text-[9px] font-title font-semibold uppercase tracking-wider px-2 py-0.5 rounded', registerStyle(ex.register)]}>
              {ex.register}
            </span>
          )}
        </div>
        <p class="word-roman text-sm italic mb-1.5">{ex.romanisation}</p>
        <p class="text-[14px] sm:text-[15px] text-slate-200">{ex.english}</p>
        {ex.literal && (
          <p class="text-[13px] text-slate-500 italic mt-1">{ex.literal}</p>
        )}
        {ex.note && (
          <p class="text-sm text-slate-400 leading-relaxed border-t border-slate-700/40 pt-2.5 mt-2.5">{ex.note}</p>
        )}
      </div>
    ))}
  </div>
</details>
