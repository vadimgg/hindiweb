---
/**
 * WordCard section: Forms chips row and usage note.
 *
 * Responsible for: forms chips row + optional english usage note inside a word card,
 * rendered as a collapsible <details> section.
 *
 * Dependencies: types.ts (Form interface).
 */
// Responsible for: forms chips row + english usage note inside a word card
import type { Form } from '../../../utils/types';

interface Props {
  forms: Form[];
  english_usage?: string;
}
const { forms, english_usage } = Astro.props;
---

{(forms.length > 0 || english_usage) && (
  <details open class="group/det border-l-2 border-l-transparent hover:border-l-amber-400/20 hover:bg-white/[0.018] transition-colors">
    <summary class="flex items-center justify-between px-4 sm:px-6 py-3 sm:py-4 cursor-pointer list-none select-none transition-colors">
      <span class="font-title text-xs sm:text-sm font-bold tracking-[0.2em] uppercase text-slate-400 group-open/det:text-slate-200 group-hover/det:text-slate-400 transition-colors">Forms</span>
      <span class="text-slate-600 group-open/det:rotate-180 transition-transform duration-200 text-xs">▾</span>
    </summary>
    <div class="px-4 sm:px-6 pb-4 pt-1 space-y-2.5">
      {forms.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {forms.map((f) => (
            <div class="bg-[#1e293b] rounded-[10px] border border-slate-700/50 px-3 py-2.5 flex flex-col gap-0.25 min-w-[7rem]">
              <span class="font-title text-[12px] font-bold uppercase tracking-[0.14em] text-slate-600">{f.label}</span>
              <span class="font-hindi text-[1.125rem] text-amber-400 leading-snug" lang="hi" style="font-family:'Tiro Devanagari Hindi',serif;">{f.hindi}</span>
              <span class="font-mono-dm text-[0.875rem] text-teal-300/70">{f.roman}</span>
            </div>
          ))}
        </div>
      )}
      {english_usage && (
        <p class="text-slate-500 text-[13px] leading-relaxed italic">{english_usage}</p>
      )}
    </div>
  </details>
)}
