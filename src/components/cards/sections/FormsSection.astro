---
/**
 * WordCard section: Forms chips row, usage note, and grouped words.
 *
 * Responsible for: forms chips row + usage note + grouped words inside a word card.
 *
 * Dependencies: cardHelpers.ts (chipClass), types.ts (Form interface).
 */
// Responsible for: forms chips row + usage note + grouped words inside a word card
import { chipClass } from '../../../utils/cardHelpers';
import type { Form } from '../../../utils/types';

interface Props {
  forms: Form[];
  english_usage?: string;
}
const { forms, english_usage } = Astro.props;
---

{(forms.length > 0 || english_usage) && (
  <div class="px-4 sm:px-6 pb-3 pt-1 space-y-2.5">
    {forms.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {forms.map((f) => (
          <span class={chipClass(f.label)}>
            <span class="font-title uppercase tracking-wide text-[11px]">{f.label}</span>
            <span class="word-hindi" lang="hi" style="font-family:'Tiro Devanagari Hindi',serif;font-size:1.1em;">{f.hindi}</span>
            <span>·</span>
            <span>{f.roman}</span>
          </span>
        ))}
      </div>
    )}
    {english_usage && (
      <p class="text-slate-500 text-[13px] leading-relaxed italic">{english_usage}</p>
    )}
  </div>
)}
