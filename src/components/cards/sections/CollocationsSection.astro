---
/**
 * WordCard section: Collocations.
 *
 * Responsible for: rendering the collocations expandable section as a scannable row list.
 *
 * Dependencies: types.ts (Collocation interface).
 */
// Responsible for: Collocations expandable section inside a word card
import type { Collocation } from '../../../utils/types';

interface Props {
  collocations: Collocation[];
}
const { collocations } = Astro.props;
---

<details class="group/det border-l-2 border-l-transparent hover:border-l-amber-400/20 hover:bg-white/[0.018] transition-colors">
  <summary class="flex items-center justify-between px-4 sm:px-6 py-3 sm:py-4 cursor-pointer list-none select-none transition-colors">
    <span class="font-title text-xs sm:text-sm font-bold tracking-[0.2em] uppercase text-slate-400 group-open/det:text-slate-200 group-hover/det:text-slate-400 transition-colors">Collocations</span>
    <span class="text-slate-600 group-open/det:rotate-180 transition-transform duration-200 text-xs">▾</span>
  </summary>
  <div class="px-4 sm:px-6 pb-4 pt-1 space-y-3">
    {collocations.map((c) => (
      <div class="flex items-baseline justify-between gap-4 py-3">
        <div class="flex flex-col gap-0.5 min-w-0">
          <span class="word-hindi text-base leading-snug" lang="hi">{c.hindi}</span>
          <span class="text-teal-300/60 text-[13px] font-mono-dm">{c.roman}</span>
        </div>
        <span class="text-slate-500 text-sm leading-snug text-right shrink-0 max-w-[55%]">{c.english}</span>
      </div>
    ))}
  </div>
</details>
