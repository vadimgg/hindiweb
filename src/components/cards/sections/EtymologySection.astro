---
/**
 * WordCard section: Etymology.
 *
 * Responsible for: rendering the etymology journey chain and optional origin note expandable section.
 * Vertical stacked layout with left connector line and stage dots, matching the demo design.
 *
 * Dependencies: types.ts (EtymologyStage interface).
 */
// Responsible for: Etymology expandable section inside a word card
import type { EtymologyStage } from '../../../utils/types';

interface Props {
  etymologyJourney: EtymologyStage[];
  originNote?: string;
}
const { etymologyJourney, originNote } = Astro.props;
---

<details class="group/det border-l-2 border-l-transparent hover:border-l-amber-400/20 hover:bg-white/[0.018] transition-colors">
  <summary class="flex items-center justify-between px-4 sm:px-6 py-3 sm:py-4 cursor-pointer list-none select-none transition-colors">
    <span class="font-title text-xs sm:text-sm font-bold tracking-[0.2em] uppercase text-slate-400 group-open/det:text-slate-200 group-hover/det:text-slate-400 transition-colors">Etymology</span>
    <span class="text-slate-600 group-open/det:rotate-180 transition-transform duration-200 text-xs">▾</span>
  </summary>
  <div class="px-4 sm:px-6 pb-4 pt-1">
    <div class="relative pl-1 border-l-2 border-slate-700/50 flex flex-col">
      {etymologyJourney.map((stage, i) => {
        const isLast = i === etymologyJourney.length - 1;
        return (
          <div class="relative flex items-start gap-3.5 py-3.5 pl-4">
            {/* Connector dot */}
            <span class:list={[
              'absolute -left-[5px] top-5 w-2 h-2 rounded-full shrink-0',
              isLast
                ? 'bg-amber-400/35 border border-amber-400/50'
                : 'bg-slate-700 border border-teal-400/25'
            ]} />
            {/* Label column */}
            <div class="min-w-[5.5rem] shrink-0 pt-0.5">
              <span class="font-title text-[12px] font-bold uppercase tracking-[0.15em] text-slate-600">{stage.stage}</span>
            </div>
            {/* Content column */}
            <div class="flex flex-wrap items-baseline gap-x-2.5 gap-y-1">
              <span
                class:list={['font-hindi text-[1.125rem] leading-snug', isLast ? 'text-amber-400' : 'text-slate-200']}
                lang="hi"
              >{stage.form}</span>
              <span class="font-mono-dm text-[0.875rem] text-teal-300/60">{stage.roman}</span>
              {stage.meaning && (
                <span class="text-[0.875rem] text-slate-500">— {stage.meaning}</span>
              )}
            </div>
          </div>
        );
      })}
    </div>
    {originNote && (
      <p class="mt-4 text-[15px] text-slate-500 italic leading-[1.7]">
        {originNote}
      </p>
    )}
  </div>
</details>
