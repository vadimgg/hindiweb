---
/**
 * WordCard section: Related Words.
 *
 * Responsible for: rendering the related words expandable section as a chip grid.
 *
 * Dependencies: types.ts (RelatedWord interface).
 */
// Responsible for: Related Words expandable section inside a word card
import type { RelatedWord } from '../../../utils/types';

interface Props {
  relatedWords: RelatedWord[];
}
const { relatedWords } = Astro.props;
---

<details class="group/det border-l-2 border-l-transparent hover:border-l-amber-400/20 hover:bg-white/[0.018] transition-colors">
  <summary class="flex items-center justify-between px-4 sm:px-6 py-3 sm:py-4 cursor-pointer list-none select-none transition-colors">
    <span class="font-title text-xs sm:text-sm font-bold tracking-[0.2em] uppercase text-slate-400 group-open/det:text-slate-200 group-hover/det:text-slate-400 transition-colors">Related Words</span>
    <span class="text-slate-600 group-open/det:rotate-180 transition-transform duration-200 text-xs">▾</span>
  </summary>
  <div class="px-4 sm:px-6 pb-4 pt-2 flex flex-wrap gap-2">
    {relatedWords.map((rw) => (
      <div class="bg-[#1e293b] rounded-[10px] px-3.5 py-2.5 border border-slate-700/50 flex flex-col gap-0.5">
        <div class="flex items-baseline gap-1.5">
          <span class="word-hindi text-base leading-none" lang="hi">{rw.hindi}</span>
          <span class="text-teal-300/70 text-[12px] font-mono-dm">{rw.roman}</span>
        </div>
        <span class="text-slate-500 text-[13px] leading-snug">{rw.english}</span>
      </div>
    ))}
  </div>
</details>
