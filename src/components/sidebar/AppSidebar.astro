---
// Responsible for: desktop sidebar — logo, search bar, words index nav, sentences index nav
interface WordEntry { w: any; i: number; }
interface WordGroup { id: string; title: string; words: WordEntry[]; }
interface DateGroup { date: string; label: string; items: { w: any; i: number }[]; }
interface Props {
  wordGroups: WordGroup[];
  totalWords: number;
  sentencesByDate: DateGroup[];
  totalSentences: number;
}
const { wordGroups, totalWords, sentencesByDate, totalSentences } = Astro.props;
---

<aside class="hidden lg:flex flex-col w-72 xl:w-80 shrink-0 sticky top-0 h-screen bg-slate-950 border-r border-slate-800/50">

  <div class="px-5 pt-7 pb-4">
    <p class="text-[10px] font-title font-semibold uppercase tracking-[0.2em] text-zinc-600 mb-1">Study companion</p>
    <h1 class="font-title text-2xl font-semibold text-zinc-100 leading-tight">Hindi<br/>Vocabulary</h1>
  </div>

  <div class="px-4 pb-3 border-b border-slate-800/50">
    <div class="relative">
      <input data-search-input type="text" autocomplete="off" spellcheck="false" placeholder="Search words…"
        class="w-full bg-slate-800/60 border border-slate-700/60 rounded-lg pl-3 pr-8 py-2 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-slate-500 transition-colors" />
      <button data-search-clear class="absolute right-2 top-1/2 -translate-y-1/2 text-slate-600 hover:text-slate-300 transition-colors hidden" aria-label="Clear search">✕</button>
    </div>
    <p id="search-count" class="text-[11px] text-slate-600 mt-1.5 px-0.5">{totalWords} words</p>
  </div>

  <nav id="idx-words" class="flex-1 overflow-y-auto py-2">
    {wordGroups.map(group => (
      <div class="date-group" data-group={group.id}>
        <div class="date-group-hdr flex items-center gap-1.5 px-2 pt-3 pb-1">
          <button class="collapse-btn shrink-0" aria-label="Collapse group"><span class="chevron">▾</span></button>
          <button class="date-group-toggle flex-1 text-left min-w-0" data-group-date={group.id}>
            <span class="group-hdr-label font-title text-[10px] font-semibold uppercase tracking-widest text-zinc-500 transition-colors">{group.title}</span>
            <span class="text-[10px] text-zinc-700 ml-1.5">{group.words.length}</span>
          </button>
          <button class="idx-checkbox group-checkbox shrink-0" data-group-date={group.id} aria-label={`Select all in ${group.title}`}></button>
        </div>
        <div class="date-group-words">
          {group.words.map(({ w, i }) => (
            <div class="idx-row flex items-center gap-2 pl-8 pr-2 py-1.5 rounded-lg mx-1" data-index={i}>
              <div class="flex-1 min-w-0 cursor-pointer" data-scroll-to={i}>
                <div class="flex items-center gap-1.5 flex-wrap">
                  <span class="text-amber-400 text-sm leading-none shrink-0" lang="hi">{w.hindi}</span>
                  <span class="text-teal-300/60 text-[11px] shrink-0">{w.romanisation}</span>
                  <span class="text-slate-200 text-[10px] bg-slate-700/50 px-1.5 py-0.5 rounded-md leading-none shrink-0">{w.english.split(',')[0].trim()}</span>
                </div>
              </div>
              <button class="idx-checkbox word-checkbox shrink-0" data-word-index={i} aria-label={`Select ${w.hindi}`}></button>
            </div>
          ))}
        </div>
      </div>
    ))}
    <p id="words-index-empty" class="hidden px-4 py-6 text-xs text-zinc-600 text-center">No matches</p>
  </nav>

  <nav id="idx-sentences" class="flex-1 overflow-y-auto py-2 hidden">
    {sentencesByDate.map(group => (
      <div class="sentence-group" data-sentence-group={group.date}>
        <div class="date-group-hdr flex items-center gap-1.5 px-2 pt-3 pb-1">
          <button class="collapse-btn shrink-0" aria-label="Collapse group"><span class="chevron">▾</span></button>
          <span class="group-hdr-label font-title text-[10px] font-semibold uppercase tracking-widest text-zinc-500">{group.label}</span>
          <span class="text-[10px] text-zinc-700 ml-1.5">{group.items.length}</span>
        </div>
        <div class="date-group-words">
          {group.items.map(({ w, i }) => (
            <div class="sentence-idx-row idx-row flex items-center gap-2 pl-8 pr-2 py-1.5 rounded-lg mx-1" data-sentence-index={i}>
              <div class="flex-1 min-w-0 cursor-pointer" data-scroll-to-sentence={i}>
                <span class="text-amber-400 text-sm leading-none" lang="hi">{(w.hindi as string).slice(0,40)}{(w.hindi as string).length > 40 ? '…' : ''}</span>
              </div>
              <button class="idx-checkbox sentence-checkbox shrink-0" data-sentence-index={i}></button>
            </div>
          ))}
        </div>
      </div>
    ))}
    {totalSentences === 0 && <p class="px-4 py-6 text-xs text-zinc-600 text-center">No sentences loaded yet.</p>}
    <p id="sentences-index-empty" class="hidden px-4 py-6 text-xs text-zinc-600 text-center">No matches</p>
  </nav>

</aside>
