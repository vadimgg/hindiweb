---
// Responsible for: word card shell — header row + section delegation
import { formatDate, categoryStyle } from '../utils/cardHelpers';
import type { Form, GroupedWith, CrossLangConnections, RootBreakdown, RootPart, PronunciationGuide, MemoryHook, UrduPunjabi, SoundAlike, Example } from '../utils/types';
import FormsSection       from './cards/sections/FormsSection.astro';
import PronunciationSection from './cards/sections/PronunciationSection.astro';
import MemorySection      from './cards/sections/MemorySection.astro';
import ExamplesSection    from './cards/sections/ExamplesSection.astro';
import RootOriginSection  from './cards/sections/RootOriginSection.astro';
import SoundAlikesSection from './cards/sections/SoundAlikesSection.astro';
import UrduPunjabiSection from './cards/sections/UrduPunjabiSection.astro';
import CrossLangSection   from './cards/sections/CrossLangSection.astro';

interface Props {
  hindi: string; romanisation: string; english: string;
  origin_language?: string; in_hindi_via?: string; word_category?: string; date_added?: string;
  english_usage?: string; grouped_with?: GroupedWith[];
  forms?: Form[]; cross_language_connections?: CrossLangConnections;
  root_breakdown?: RootBreakdown; root_parts?: RootPart[]; root_notes?: string[];
  root_and_origin_explanation?: string[]; etymology_story?: string | string[];
  pronunciation_guide?: PronunciationGuide; memory_hook?: MemoryHook;
  urdu_punjabi?: UrduPunjabi; sound_alikes?: SoundAlike[]; examples?: Example[]; index: number;
}

const {
  hindi, romanisation, english, origin_language, in_hindi_via, word_category, date_added,
  english_usage, grouped_with = [],
  forms = [], cross_language_connections, root_breakdown, root_parts = [], root_notes = [],
  root_and_origin_explanation = [], etymology_story, pronunciation_guide,
  memory_hook, urdu_punjabi, sound_alikes = [], examples = [], index,
} = Astro.props;

const [primaryMeaning, ...rest] = english.split(',').map((s: string) => s.trim()).filter(Boolean);
const secondaryMeanings = rest.join(', ');

const hasPron = !!(pronunciation_guide?.syllables || (pronunciation_guide?.breakdown ?? []).length > 0 || (pronunciation_guide?.extra_notes ?? []).length > 0 || (pronunciation_guide?.tips ?? []).length > 0);
const hasRoot = !!(root_breakdown?.root || root_breakdown?.evolution || root_breakdown?.logic || root_parts.length > 0 || root_notes.length > 0 || root_and_origin_explanation.length > 0 || (Array.isArray(etymology_story) ? etymology_story.length > 0 : !!etymology_story));
const hookPrimary    = memory_hook?.primary ?? '';
const hookConnection = memory_hook?.connection ?? '';
const hookByLanguage = Object.entries(memory_hook ?? {}).filter(([k]) => k !== 'primary' && k !== 'connection') as [string, string][];
const hasMemory      = !!(hookPrimary || hookConnection || hookByLanguage.length > 0);
const trueRelatives      = cross_language_connections?.true_relatives    ?? [];
const usefulCoincidences = cross_language_connections?.useful_coincidences ?? [];
---

<article id={`card-${index}`} class="bg-slate-900 border border-slate-700/40 rounded-2xl overflow-hidden hover:border-slate-600/60 transition-colors is-collapsed">

  <div class="card-header flex flex-wrap items-center gap-2 px-4 sm:px-5 py-3 sm:py-4 cursor-pointer hover:bg-slate-800/20 transition-colors select-none">
    <h2 class="word-hindi text-2xl sm:text-3xl font-bold leading-none shrink-0" lang="hi">{hindi}</h2>
    <span class="text-slate-700 shrink-0">·</span>
    <span class="word-roman text-base sm:text-lg leading-none shrink-0">{romanisation}</span>
    <span class="text-slate-200 text-xs bg-slate-800/70 px-2.5 py-1 rounded-lg border border-slate-700/50 shrink-0 leading-none">{primaryMeaning}</span>
    <div class="flex-1 min-w-0"></div>
    {word_category && (
      <span class:list={['shrink-0 text-xs font-title font-semibold uppercase tracking-wider px-2.5 py-1 rounded-lg', categoryStyle(word_category)]}>
        {word_category}
      </span>
    )}
    {origin_language && (
      <span class="shrink-0 text-xs font-title font-semibold uppercase tracking-wider px-2.5 py-1 rounded-lg bg-amber-900/20 text-amber-600/80 border border-amber-800/30 whitespace-nowrap">
        {origin_language}
      </span>
    )}
    <button class="deselect-btn shrink-0 text-xs text-slate-600 hover:text-slate-300 w-5 h-5 flex items-center justify-center" data-deselect-index={index} aria-label="Deselect word">✕</button>
  </div>

  <div class="card-expandable">
    <FormsSection forms={forms} secondaryMeanings={secondaryMeanings} english_usage={english_usage} grouped_with={grouped_with} />

    <div class="border-t border-slate-700/40 divide-y divide-slate-700/40">
      {hasPron         && <PronunciationSection pronunciation_guide={pronunciation_guide!} />}
      {hasMemory       && <MemorySection hookPrimary={hookPrimary} hookConnection={hookConnection} hookByLanguage={hookByLanguage} />}
      {examples.length > 0 && <ExamplesSection examples={examples} index={index} />}
      {hasRoot         && <RootOriginSection in_hindi_via={in_hindi_via} root_parts={root_parts} root_breakdown={root_breakdown} root_notes={root_notes} root_and_origin_explanation={root_and_origin_explanation} etymology_story={etymology_story} />}
      {sound_alikes.length > 0  && <SoundAlikesSection sound_alikes={sound_alikes} />}
      {urdu_punjabi && (urdu_punjabi.urdu || urdu_punjabi.punjabi) && <UrduPunjabiSection urdu_punjabi={urdu_punjabi} />}
      {(trueRelatives.length > 0 || usefulCoincidences.length > 0) && <CrossLangSection trueRelatives={trueRelatives} usefulCoincidences={usefulCoincidences} />}
    </div>

    {date_added && (
      <div class="px-5 py-2.5 border-t border-slate-800/50">
        <p class="text-[11px] text-slate-700">{formatDate(date_added)}</p>
      </div>
    )}
  </div>

</article>
