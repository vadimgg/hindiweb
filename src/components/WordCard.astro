---
/**
 * Word card shell — header row and section delegation.
 *
 * Responsible for: rendering the full word card with header, grammar badges, and expandable sections.
 *
 * Dependencies: cardHelpers.ts (formatDate, categoryStyle),
 *               types.ts (Form, Collocation, RelatedWord, SoundAlike, EtymologyStage),
 *               FormsSection, UsageNotesSection, CollocationsSection,
 *               RelatedWordsSection, SoundAlikesSection, EtymologySection.
 */
// Responsible for: word card shell — header row + section delegation
import { formatDate, categoryStyle } from '../utils/cardHelpers';
import type { Form, Collocation, RelatedWord, SoundAlike, EtymologyStage } from '../utils/types';
import FormsSection       from './cards/sections/FormsSection.astro';
import UsageNotesSection  from './cards/sections/UsageNotesSection.astro';
import CollocationsSection from './cards/sections/CollocationsSection.astro';
import RelatedWordsSection from './cards/sections/RelatedWordsSection.astro';
import SoundAlikesSection from './cards/sections/SoundAlikesSection.astro';
import EtymologySection   from './cards/sections/EtymologySection.astro';

interface Props {
  hindi: string;
  romanisation: string;
  english: string;
  date_added?: string;
  english_usage?: string;
  forms?: Form[];
  pos?: string;
  gender?: string;
  transitivity?: string;
  syllables?: string;
  collocations?: Collocation[];
  usage_notes?: string;
  related_words?: RelatedWord[];
  sound_alikes?: SoundAlike[];
  etymology_journey?: EtymologyStage[];
  origin_note?: string;
  index: number;
}

const {
  hindi, romanisation, english, date_added, english_usage,
  forms: _forms, pos, gender, transitivity, syllables,
  collocations: _collocations, usage_notes,
  related_words: _related_words, sound_alikes: _sound_alikes,
  etymology_journey: _etymology_journey, origin_note, index,
} = Astro.props;

const forms           = _forms           ?? [];
const collocations    = _collocations    ?? [];
const related_words   = _related_words   ?? [];
const sound_alikes    = _sound_alikes    ?? [];
const etymology_journey = _etymology_journey ?? [];

const [primaryMeaning, ...rest] = english.split(',').map((s: string) => s.trim()).filter(Boolean);
const secondaryMeanings = rest.join(', ');
---

<article id={`card-${index}`} class="bg-slate-900 border border-slate-700/40 rounded-2xl overflow-hidden hover:border-slate-600/60 transition-colors is-collapsed">

  <div class="card-header flex px-4 sm:px-5 py-3 sm:py-4 gap-2 cursor-pointer hover:bg-slate-800/20 transition-colors select-none">
    <div class="flex-1 min-w-0 flex flex-col gap-1.5 py-1">
      <!-- Row 1: phonetic identity -->
      <div class="flex flex-wrap items-baseline gap-x-2 gap-y-0.5">
        <h2 class="word-hindi text-2xl sm:text-3xl font-bold leading-none shrink-0" lang="hi">{hindi}</h2>
        <span class="text-slate-700 shrink-0">·</span>
        <span class="word-roman text-base sm:text-lg leading-none shrink-0">{romanisation}</span>
        {syllables && (
          <>
            <span class="text-slate-700 shrink-0">·</span>
            <span class="text-teal-300/60 text-sm font-mono tracking-widest shrink-0">{syllables}</span>
          </>
        )}
      </div>
      <!-- Row 2: meaning -->
      <div class="flex flex-wrap items-center gap-1.5">
        <span class="text-slate-200 text-sm leading-none">{primaryMeaning}</span>
        {secondaryMeanings && (
          <span class="text-slate-500 text-xs leading-none">{secondaryMeanings}</span>
        )}
      </div>
      <!-- Row 3: grammar badges -->
      <div class="flex flex-wrap items-center gap-1.5 mt-0.5">
        {pos && (
          <span class:list={['text-xs font-title font-semibold uppercase tracking-wider px-2.5 py-1 rounded-lg', categoryStyle(pos)]}>
            {pos}
          </span>
        )}
        {gender === 'masculine' && (
          <span class="text-xs font-title font-semibold uppercase tracking-wider px-2.5 py-1 rounded-lg bg-blue-900/20 text-blue-300/80 border border-blue-700/30">
            m
          </span>
        )}
        {gender === 'feminine' && (
          <span class="text-xs font-title font-semibold uppercase tracking-wider px-2.5 py-1 rounded-lg bg-pink-900/20 text-pink-300/80 border border-pink-700/30">
            f
          </span>
        )}
        {transitivity && (
          <span class="text-xs font-title font-semibold uppercase tracking-wider px-2.5 py-1 rounded-lg bg-slate-800/60 text-slate-400 border border-slate-700/40">
            {transitivity === 'transitive' ? 'trans.' : 'intrans.'}
          </span>
        )}
      </div>
    </div>
    <div class="shrink-0 flex items-start">
      <button class="deselect-btn text-xs text-slate-600 hover:text-slate-300 w-5 h-5 flex items-center justify-center mt-1 transition-colors" data-deselect-index={index} aria-label="Deselect word">✕</button>
    </div>
  </div>

  <div class="card-expandable">
    <FormsSection forms={forms} english_usage={english_usage} />

    <div class="border-t border-slate-700/40 divide-y divide-slate-700/40">
      {usage_notes                  && <UsageNotesSection usageNotes={usage_notes} />}
      {collocations.length > 0      && <CollocationsSection collocations={collocations} />}
      {related_words.length > 0     && <RelatedWordsSection relatedWords={related_words} />}
      {sound_alikes.length > 0      && <SoundAlikesSection sound_alikes={sound_alikes} />}
      {etymology_journey.length > 0 && <EtymologySection etymologyJourney={etymology_journey} originNote={origin_note} />}
    </div>

    {date_added && (
      <div class="px-5 py-2.5 border-t border-slate-800/50">
        <p class="text-[11px] text-slate-700">{formatDate(date_added)}</p>
      </div>
    )}
  </div>

</article>
