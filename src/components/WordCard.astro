---
import { highlight } from '../utils/highlight';

interface Example {
  hindi: string;
  romanisation: string;
  english: string;
  literal?: string;
  register?: string;
  note?: string;
}

interface Form {
  label: string;
  hindi: string;
  roman: string;
}

interface RootPart {
  element: string;
  script: string;
  meaning: string;
}

interface CrossLangItem {
  language?: string;
  word?: string;
  romanisation?: string;
  meaning?: string;
  note?: string;
}

interface CrossLangConnections {
  true_relatives?: CrossLangItem[];
  useful_coincidences?: CrossLangItem[];
}

interface PronBreakdownItem {
  syllable: string;
  note: string;
}

interface PronunciationGuide {
  syllables?: string;
  breakdown?: PronBreakdownItem[];
  stress?: string;
  extra_notes?: string[];
}

interface SoundAlike {
  language?: string;
  word?: string;
  romanisation?: string;
  meaning?: string;
  relation_type?: string;
  note?: string;
}

interface Props {
  hindi: string;
  romanisation: string;
  english: string;
  origin_language?: string;
  in_hindi_via?: string;
  word_category?: string;
  date_added?: string;
  forms?: Form[];
  cross_language_connections?: CrossLangConnections;
  root_breakdown?: string[];
  root_parts?: RootPart[];
  root_notes?: string[];
  root_and_origin_explanation?: string[];
  etymology_story?: string[];
  pronunciation_guide?: PronunciationGuide;
  memory_hook?: string[];
  sound_alikes?: SoundAlike[];
  examples?: Example[];
  index: number;
}

const {
  hindi,
  romanisation,
  english,
  origin_language,
  in_hindi_via,
  word_category,
  date_added,
  forms = [],
  cross_language_connections,
  root_breakdown = [],
  root_parts = [],
  root_notes = [],
  root_and_origin_explanation = [],
  etymology_story = [],
  pronunciation_guide,
  memory_hook = [],
  sound_alikes = [],
  examples = [],
  index,
} = Astro.props;

// Format "2026-03-28" → "Mar 28, 2026"
function formatDate(iso: string): string {
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const [y, m, d] = iso.split('-');
  return `${months[parseInt(m) - 1]} ${parseInt(d)}, ${y}`;
}

const [primaryMeaning, ...restMeanings] = english.split(',').map((s: string) => s.trim()).filter(Boolean);
const secondaryMeanings = restMeanings.join(', ');

function chipClass(label: string): string {
  const l = label.toLowerCase();
  if (l.includes('feminine'))   return 'form-chip form-chip-fem';
  if (l.includes('masculine'))  return 'form-chip form-chip-masc';
  if (l.includes('oblique'))    return 'form-chip form-chip-indigo';
  if (l.includes('invariable')) return 'form-chip form-chip-teal';
  if (l.includes('adverb'))     return 'form-chip form-chip-sky';
  if (l.includes('adjective'))  return 'form-chip form-chip-amber';
  if (l.includes('noun'))       return 'form-chip form-chip-violet';
  if (l.includes('number') || l.includes('cardinal') || l.includes('article')) return 'form-chip form-chip-emerald';
  if (l.includes('compound'))   return 'form-chip form-chip-rose';
  return 'form-chip';
}

function categoryStyle(cat: string): string {
  const c = cat.toLowerCase();
  if (c.includes('conjunction'))  return 'bg-emerald-900/30 text-emerald-400 border border-emerald-700/40';
  if (c.includes('adverb'))       return 'bg-sky-900/30 text-sky-400 border border-sky-700/40';
  if (c.includes('noun'))         return 'bg-violet-900/30 text-violet-400 border border-violet-700/40';
  if (c.includes('adjective'))    return 'bg-amber-900/30 text-amber-500 border border-amber-700/40';
  if (c.includes('verb'))         return 'bg-orange-900/30 text-orange-400 border border-orange-700/40';
  if (c.includes('preposition') || c.includes('postposition')) return 'bg-rose-900/30 text-rose-400 border border-rose-700/40';
  if (c.includes('particle'))     return 'bg-teal-900/30 text-teal-400 border border-teal-700/40';
  if (c.includes('pronoun'))      return 'bg-indigo-900/30 text-indigo-400 border border-indigo-700/40';
  return 'bg-slate-800/60 text-slate-400 border border-slate-600/40';
}

function registerStyle(reg: string): string {
  const r = reg.toLowerCase();
  if (r === 'standard')   return 'text-sky-400/70 bg-sky-950/50 border border-sky-800/30';
  if (r === 'casual')     return 'text-amber-400/70 bg-amber-950/50 border border-amber-800/30';
  if (r === 'colloquial') return 'text-rose-400/70 bg-rose-950/50 border border-rose-800/30';
  if (r === 'formal')     return 'text-violet-400/70 bg-violet-950/50 border border-violet-800/30';
  return 'text-slate-400/70 bg-slate-800/40 border border-slate-700/30';
}

const labelStyle = {
  'TRUE RELATIVE':      'bg-sky-950 text-sky-400 border border-sky-800/50',
  'USEFUL COINCIDENCE': 'bg-slate-800 text-slate-400 border border-slate-700/60',
} as const;

// Language badge colour for structured fields (cross-lang, sound-alikes headers)
function langColor(lang: string): string {
  const map: Record<string, string> = {
    'Proto-Indo-European': 'text-teal-200/70',
    'PIE':                 'text-teal-200/70',
    'Sanskrit':            'text-amber-300/80',
    'Prakrit':             'text-amber-200/65',
    'Apabhraṃśa':          'text-amber-200/65',
    'Hindi':               'text-amber-400/80',
    'Urdu':                'text-amber-500/75',
    'Arabic':              'text-orange-400/75',
    'Persian':             'text-pink-400/70',
    'English':             'text-sky-400/75',
    'Russian':             'text-cyan-300/75',
    'Hebrew':              'text-emerald-300/75',
    'Latin':               'text-violet-300/70',
    'Greek':               'text-indigo-400/70',
    'French':              'text-violet-400/70',
    'German':              'text-slate-400/70',
    'Italian':             'text-green-300/70',
    'Spanish':             'text-red-300/70',
  };
  return map[lang] ?? 'text-slate-400/70';
}

const trueRelatives    = cross_language_connections?.true_relatives    ?? [];
const usefulCoincidences = cross_language_connections?.useful_coincidences ?? [];
const hasCrossLang = trueRelatives.length > 0 || usefulCoincidences.length > 0;

const hasPron = !!(pronunciation_guide?.syllables || (pronunciation_guide?.breakdown ?? []).length > 0 || (pronunciation_guide?.extra_notes ?? []).length > 0);
const hasRoot = root_breakdown.length > 0 || root_parts.length > 0 || root_notes.length > 0 || root_and_origin_explanation.length > 0;
---

<article
  id={`card-${index}`}
  class="bg-slate-900 border border-slate-700/40 rounded-2xl overflow-hidden hover:border-slate-600/60 transition-colors is-collapsed"
>

  <!-- ── Card header (always visible, click row to collapse/expand) ───── -->
  <div class="card-header flex items-center gap-3 px-5 py-4 cursor-pointer hover:bg-slate-800/20 transition-colors select-none">

    <!-- Collapse chevron -->
    <button class="card-collapse-btn shrink-0 w-6 h-6 flex items-center justify-center rounded text-slate-600 hover:text-slate-300 hover:bg-slate-800/60 transition-colors" aria-label="Collapse card">
      <span class="chevron text-[10px]">▾</span>
    </button>

    <!-- Hindi word -->
    <h2 class="word-hindi text-3xl font-bold leading-none shrink-0" lang="hi">{hindi}</h2>

    <!-- Separator -->
    <span class="text-slate-700 shrink-0">·</span>

    <!-- Romanisation -->
    <span class="word-roman text-lg leading-none shrink-0">{romanisation}</span>

    <!-- Meaning pill -->
    <span class="text-slate-200 text-sm bg-slate-800/70 px-2.5 py-1 rounded-lg border border-slate-700/50 shrink-0 leading-none">
      {primaryMeaning}
    </span>

    <!-- Spacer -->
    <div class="flex-1 min-w-0"></div>

    <!-- Category badge -->
    {word_category && (
      <span class:list={['shrink-0 text-xs font-title font-semibold uppercase tracking-wider px-2.5 py-1 rounded-lg', categoryStyle(word_category)]}>
        {word_category}
      </span>
    )}

    <!-- Origin badge -->
    {origin_language && (
      <span class="shrink-0 text-xs font-title font-semibold uppercase tracking-wider px-2.5 py-1 rounded-lg bg-amber-900/20 text-amber-600/80 border border-amber-800/30 whitespace-nowrap">
        {origin_language}
      </span>
    )}

    <!-- Deselect button -->
    <button class="deselect-btn shrink-0" data-deselect-index={index} aria-label="Deselect word">✕</button>
  </div>

  <!-- ── Everything below the header row ─────────────────────────────── -->
  <div class="card-expandable">

    <!-- Forms + secondary meanings -->
    {(forms.length > 0 || secondaryMeanings) && (
      <div class="px-5 pb-4 pt-1 space-y-3">
        {forms.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {forms.map((f) => (
              <span class={chipClass(f.label)}>
                <span class="font-title uppercase tracking-wide text-[10px]">{f.label}</span>
                <span class="word-hindi" lang="hi" style="font-family:'Tiro Devanagari Hindi',serif;font-size:1.1em;">{f.hindi}</span>
                <span>·</span>
                <span>{f.roman}</span>
              </span>
            ))}
          </div>
        )}
        {secondaryMeanings && (
          <div class="bg-slate-800/50 rounded-xl px-4 py-2.5">
            <p class="text-slate-300 text-sm leading-relaxed">{secondaryMeanings}</p>
          </div>
        )}
      </div>
    )}

  <!-- ── Expandable sections ─────────────────────────────────────────── -->
  <div class="border-t border-slate-700/40 divide-y divide-slate-700/40">

    <!-- Pronunciation -->
    {hasPron && (
      <details class="group/det">
        <summary class="flex items-center justify-between px-7 py-4 cursor-pointer list-none select-none hover:bg-slate-800/30 transition-colors">
          <span class="font-title text-sm font-medium tracking-wider uppercase text-slate-400 group-open/det:text-slate-200 transition-colors">Pronunciation</span>
          <span class="text-slate-600 group-open/det:rotate-180 transition-transform duration-200 text-xs">▾</span>
        </summary>
        <div class="px-7 pb-6 pt-3">
          <div class="bg-slate-950/70 border-l-2 border-teal-500/50 rounded-r-xl px-5 py-4 space-y-3">
            {pronunciation_guide!.syllables && (
              <p class="text-teal-300 text-lg font-semibold tracking-widest font-title">{pronunciation_guide!.syllables}</p>
            )}
            {(pronunciation_guide!.breakdown ?? []).map((item) => (
              <div class="flex gap-3 items-start">
                <span class="font-title font-semibold text-sm text-slate-100 shrink-0 w-12">{item.syllable}</span>
                <p class="text-[15px] text-slate-300 leading-relaxed">{item.note}</p>
              </div>
            ))}
            {pronunciation_guide!.stress && (
              <p class="text-sm text-amber-400/80 italic border-t border-slate-800/60 pt-3">{pronunciation_guide!.stress}</p>
            )}
            {(pronunciation_guide!.extra_notes ?? []).map((note) => (
              <p class="text-[15px] text-slate-400 leading-relaxed" set:html={highlight(note)} />
            ))}
          </div>
        </div>
      </details>
    )}

    <!-- Memory Hook -->
    {memory_hook.length > 0 && (
      <details class="group/det">
        <summary class="flex items-center justify-between px-7 py-4 cursor-pointer list-none select-none hover:bg-slate-800/30 transition-colors">
          <span class="font-title text-sm font-medium tracking-wider uppercase text-slate-400 group-open/det:text-slate-200 transition-colors">Memory Hook</span>
          <span class="text-slate-600 group-open/det:rotate-180 transition-transform duration-200 text-xs">▾</span>
        </summary>
        <div class="px-7 pb-6 pt-3 space-y-3">
          {memory_hook.map((line) => (
            <div class="bg-slate-950/80 border-l-2 border-violet-500/60 rounded-r-xl px-5 py-4">
              <p class="text-[15px] text-slate-200 leading-relaxed" set:html={highlight(line)} />
            </div>
          ))}
        </div>
      </details>
    )}

    <!-- Examples -->
    {examples.length > 0 && (
      <details class="group/det">
        <summary class="flex items-center justify-between px-7 py-4 cursor-pointer list-none select-none hover:bg-slate-800/30 transition-colors">
          <span class="font-title text-sm font-medium tracking-wider uppercase text-slate-400 group-open/det:text-slate-200 transition-colors">Examples</span>
          <span class="text-slate-600 group-open/det:rotate-180 transition-transform duration-200 text-xs">▾</span>
        </summary>
        <div class="px-7 pb-6 pt-3 space-y-3">
          {examples.map((ex) => (
            <div class="bg-slate-950/60 border border-slate-700/30 rounded-xl p-5">
              <div class="flex items-start justify-between gap-2 mb-1.5">
                <p class="word-hindi text-lg font-medium leading-snug" lang="hi">{ex.hindi}</p>
                {ex.register && (
                  <span class:list={['shrink-0 text-[10px] font-title font-semibold uppercase tracking-wider px-2 py-0.5 rounded', registerStyle(ex.register)]}>
                    {ex.register}
                  </span>
                )}
              </div>
              <p class="word-roman text-sm italic mb-2">{ex.romanisation}</p>
              <p class="text-[15px] text-slate-200">{ex.english}</p>
              {ex.literal && (
                <p class="text-[13px] text-slate-500 italic mt-1">{ex.literal}</p>
              )}
              {ex.note && (
                <p class="text-sm text-slate-400 leading-relaxed border-t border-slate-700/40 pt-2.5 mt-2.5">{ex.note}</p>
              )}
            </div>
          ))}
        </div>
      </details>
    )}

    <!-- Root & Origin -->
    {hasRoot && (
      <details class="group/det">
        <summary class="flex items-center justify-between px-7 py-4 cursor-pointer list-none select-none hover:bg-slate-800/30 transition-colors">
          <span class="font-title text-sm font-medium tracking-wider uppercase text-slate-400 group-open/det:text-slate-200 transition-colors">Root &amp; Origin</span>
          <span class="text-slate-600 group-open/det:rotate-180 transition-transform duration-200 text-xs">▾</span>
        </summary>
        <div class="px-7 pb-6 pt-3">
          <div class="bg-slate-950/70 border-l-2 border-blue-500/40 rounded-r-xl px-5 py-4 space-y-3">
            {in_hindi_via && (
              <p class="text-[13px] text-blue-300/70 italic">{in_hindi_via}</p>
            )}
            {root_parts.length > 0 && (
              <div class="space-y-2">
                {root_parts.map((part) => (
                  <div class="flex items-baseline gap-2">
                    <span class="word-hindi text-base shrink-0" lang="hi">{part.script}</span>
                    <span class="word-roman text-sm shrink-0">{part.element}</span>
                    <span class="text-slate-400 text-sm">— {part.meaning}</span>
                  </div>
                ))}
              </div>
            )}
            {root_breakdown.map((line, i) => (
              <p class:list={['leading-relaxed', i === 0 ? 'text-slate-100 text-base font-medium' : 'text-[15px] text-slate-300']}
                set:html={highlight(line)} />
            ))}
            {root_notes.map((line) => (
              <p class="text-[15px] text-slate-300 leading-relaxed" set:html={highlight(line)} />
            ))}
            {root_and_origin_explanation.map((line, i) => (
              <p class:list={['leading-relaxed', i === 0 ? 'text-slate-100 text-base font-medium' : 'text-[15px] text-slate-300']}
                set:html={highlight(line)} />
            ))}
          </div>
        </div>
      </details>
    )}

    <!-- Etymology Story -->
    {etymology_story.length > 0 && (
      <details class="group/det">
        <summary class="flex items-center justify-between px-7 py-4 cursor-pointer list-none select-none hover:bg-slate-800/30 transition-colors">
          <span class="font-title text-sm font-medium tracking-wider uppercase text-slate-400 group-open/det:text-slate-200 transition-colors">Etymology Story</span>
          <span class="text-slate-600 group-open/det:rotate-180 transition-transform duration-200 text-xs">▾</span>
        </summary>
        <div class="px-7 pb-6 pt-3">
          <div class="bg-slate-950/80 border-l-2 border-amber-500/50 rounded-r-xl px-5 py-4 space-y-4">
            {etymology_story.map((para) => (
              <p class="text-base text-slate-200 leading-relaxed" set:html={highlight(para)} />
            ))}
          </div>
        </div>
      </details>
    )}

    <!-- Sound Alikes -->
    {sound_alikes.length > 0 && (
      <details class="group/det">
        <summary class="flex items-center justify-between px-7 py-4 cursor-pointer list-none select-none hover:bg-slate-800/30 transition-colors">
          <span class="font-title text-sm font-medium tracking-wider uppercase text-slate-400 group-open/det:text-slate-200 transition-colors">Sound Alikes</span>
          <span class="text-slate-600 group-open/det:rotate-180 transition-transform duration-200 text-xs">▾</span>
        </summary>
        <div class="px-7 pb-6 pt-3">
          <div class="bg-slate-950/70 border-l-2 border-rose-500/40 rounded-r-xl px-5 py-4 space-y-4">
            {sound_alikes.map((sa) => (
              <div>
                <div class="flex items-center gap-2 flex-wrap mb-1.5">
                  {sa.relation_type && (
                    <span class:list={[
                      'font-title text-[10px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded',
                      sa.relation_type === 'TRUE RELATIVE' ? labelStyle['TRUE RELATIVE'] : labelStyle['USEFUL COINCIDENCE'],
                    ]}>
                      {sa.relation_type === 'TRUE RELATIVE' ? 'relative' : 'coincidence'}
                    </span>
                  )}
                  {sa.language && <span class:list={['text-[11px] font-title font-semibold uppercase tracking-wide', langColor(sa.language)]}>{sa.language}</span>}
                  {sa.word && <span class="word-hindi text-base" lang="hi" set:html={highlight(sa.word)} />}
                  {sa.romanisation && <span class="word-roman text-sm">({sa.romanisation})</span>}
                  {sa.meaning && <span class="text-slate-400 text-sm">— {sa.meaning}</span>}
                </div>
                {sa.note && <p class="text-[15px] text-slate-300 leading-relaxed" set:html={highlight(sa.note)} />}
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

    <!-- Cross-Language Connections -->
    {hasCrossLang && (
      <details class="group/det">
        <summary class="flex items-center justify-between px-7 py-4 cursor-pointer list-none select-none hover:bg-slate-800/30 transition-colors">
          <span class="font-title text-sm font-medium tracking-wider uppercase text-slate-400 group-open/det:text-slate-200 transition-colors">Cross-Language</span>
          <span class="text-slate-600 group-open/det:rotate-180 transition-transform duration-200 text-xs">▾</span>
        </summary>
        <div class="px-7 pb-6 pt-3">
          <div class="bg-slate-950/70 border-l-2 border-sky-500/40 rounded-r-xl px-5 py-4 space-y-5">
            {trueRelatives.map((item) => (
              <div>
                <div class="flex items-center gap-2 flex-wrap mb-1.5">
                  <span class:list={['shrink-0 font-title text-[10px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded', labelStyle['TRUE RELATIVE']]}>relative</span>
                  {item.language && <span class:list={['text-[11px] font-title font-semibold uppercase tracking-wide', langColor(item.language)]}>{item.language}</span>}
                  {item.word && <span class="word-hindi text-base" lang="hi" set:html={highlight(item.word)} />}
                  {item.romanisation && <span class="word-roman text-sm">({item.romanisation})</span>}
                  {item.meaning && <span class="text-slate-400 text-sm">— {item.meaning}</span>}
                </div>
                {item.note && <p class="text-[15px] text-slate-300 leading-relaxed" set:html={highlight(item.note)} />}
              </div>
            ))}
            {usefulCoincidences.map((item) => (
              <div>
                <div class="flex items-center gap-2 flex-wrap mb-1.5">
                  <span class:list={['shrink-0 font-title text-[10px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded', labelStyle['USEFUL COINCIDENCE']]}>coincidence</span>
                  {item.language && <span class:list={['text-[11px] font-title font-semibold uppercase tracking-wide', langColor(item.language)]}>{item.language}</span>}
                  {item.word && <span class="word-hindi text-base" lang="hi" set:html={highlight(item.word)} />}
                  {item.romanisation && <span class="word-roman text-sm">({item.romanisation})</span>}
                  {item.meaning && <span class="text-slate-400 text-sm">— {item.meaning}</span>}
                </div>
                {item.note && <p class="text-[15px] text-slate-300 leading-relaxed" set:html={highlight(item.note)} />}
              </div>
            ))}
          </div>
        </div>
      </details>
    )}

  </div>

  <!-- ── Card footer: date ──────────────────────────────────────────── -->
  {date_added && (
    <div class="px-5 py-2.5 border-t border-slate-800/50">
      <p class="text-[11px] text-slate-700">{formatDate(date_added)}</p>
    </div>
  )}

  </div>{/* end card-expandable */}

</article>
