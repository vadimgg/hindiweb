---
import Layout from '../layouts/Layout.astro';
import WordCard from '../components/WordCard.astro';
import SentenceCard from '../components/SentenceCard.astro';
import { readdir, readFile } from 'node:fs/promises';
import { join } from 'node:path';

// ── Load words ────────────────────────────────────────────────────────────────
const vocabDir   = join(process.cwd(), 'vocab');
const vocabFiles = (await readdir(vocabDir)).filter(f => f.endsWith('.json')).sort();

// Each file is { title: string, words: [...] }
const allFiles = await Promise.all(
  vocabFiles.map(async (f) => {
    const data = JSON.parse(await readFile(join(vocabDir, f), 'utf-8'));
    const title = (typeof data === 'object' && !Array.isArray(data) && data.title)
      ? data.title
      : f.replace('.json', '').replace(/_/g, ' ');
    const words = Array.isArray(data) ? data : (data.words ?? []);
    return { title, words };
  })
);
const allWords = allFiles.flatMap(f => f.words);

// Word groups for sidebar (grouped by file title)
const wordGroups = (() => {
  let offset = 0;
  return allFiles
    .filter(f => f.words.length > 0)
    .map((file, fi) => {
      const group = {
        id: String(fi),
        title: file.title,
        words: file.words.map((w: any, li: number) => ({ w, i: offset + li })),
      };
      offset += file.words.length;
      return group;
    });
})();

// ── Load sentences (graceful — dir may not exist yet) ─────────────────────────
let allSentences: any[] = [];
try {
  const sentencesDir   = join(process.cwd(), 'sentences');
  const sentenceFiles  = (await readdir(sentencesDir)).filter(f => f.endsWith('.json')).sort();
  allSentences = (
    await Promise.all(
      sentenceFiles.map(async (f) => JSON.parse(await readFile(join(sentencesDir, f), 'utf-8')))
    )
  ).flat();
} catch { /* sentences/ doesn't exist yet */ }

// ── Search payloads (sent to the client) ──────────────────────────────────────
const wordSearchIndex = allWords.map((w, i) => ({
  i,
  h: w.hindi,
  r: w.romanisation,
  e: w.english,
  d: w.date_added ?? '',
}));

const sentenceSearchIndex = allSentences.map((s, i) => ({
  i,
  h: s.hindi    ?? '',
  r: s.romanisation ?? '',
  e: s.english  ?? '',
  d: s.date_added ?? '',
}));

// Hover-preview annotation data (words only)
const hoverData = allWords.map((w, i) => ({
  i,
  hindi:   w.hindi,
  roman:   w.romanisation,
  english: (w.english as string).split(',')[0].trim(),
  forms:   (w.forms || []).map((f: { hindi: string; roman: string }) => ({ h: f.hindi, r: f.roman })),
}));

// ── Date helpers (for sentences) ─────────────────────────────────────────────
function fmtDate(iso: string): string {
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const [y, m, d] = iso.split('-');
  return `${months[parseInt(m) - 1]} ${parseInt(d)}, ${y}`;
}

function groupByDate<T extends { date_added?: string }>(items: T[]) {
  const uniqueDates = [...new Set(items.map(w => w.date_added).filter(Boolean) as string[])]
    .sort((a, b) => b.localeCompare(a));
  const byDate = uniqueDates.map(date => ({
    date,
    label: fmtDate(date),
    items: items.map((w, i) => ({ w, i })).filter(({ w }) => (w.date_added ?? '') === date),
  }));
  const undated = items.map((w, i) => ({ w, i })).filter(({ w }) => !w.date_added);
  return { byDate, undated };
}

const sentences = groupByDate(allSentences);
---

<Layout title="Hindi Vocabulary">
  <div class="lg:flex min-h-screen">

    <!-- ── Sidebar ─────────────────────────────────────────────────────────── -->
    <aside class="hidden lg:flex flex-col w-72 xl:w-80 shrink-0 sticky top-0 h-screen bg-slate-950 border-r border-slate-800/50">

      <!-- Branding -->
      <div class="px-5 pt-7 pb-4">
        <p class="text-[10px] font-title font-semibold uppercase tracking-[0.2em] text-zinc-600 mb-1">Study companion</p>
        <h1 class="font-title text-2xl font-semibold text-zinc-100 leading-tight">Hindi<br/>Vocabulary</h1>
      </div>

      <!-- Search -->
      <div class="px-4 pb-3 border-b border-slate-800/50">
        <div class="relative">
          <input
            id="search"
            type="text"
            autocomplete="off"
            spellcheck="false"
            placeholder="Search words…"
            class="w-full bg-slate-800/60 border border-slate-700/60 rounded-lg pl-3 pr-8 py-2 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-slate-500 transition-colors"
          />
          <button id="search-clear" class="absolute right-2 top-1/2 -translate-y-1/2 text-slate-600 hover:text-slate-300 transition-colors hidden" aria-label="Clear search">✕</button>
        </div>
        <p id="search-count" class="text-[11px] text-slate-600 mt-1.5 px-0.5">{allWords.length} words</p>
      </div>

      <!-- Index: words (grouped by file title) -->
      <nav id="idx-words" class="flex-1 overflow-y-auto py-2">
        {wordGroups.map(group => (
          <div class="date-group" data-group={group.id}>
            <!-- Group header: [▾] title + count  [□ group checkbox] -->
            <div class="date-group-hdr flex items-center gap-1.5 px-2 pt-3 pb-1">
              <button class="collapse-btn shrink-0" aria-label="Collapse group">
                <span class="chevron">▾</span>
              </button>
              <button class="date-group-toggle flex-1 text-left min-w-0" data-group-date={group.id}>
                <span class="group-hdr-label font-title text-[10px] font-semibold uppercase tracking-widest text-zinc-500 transition-colors">{group.title}</span>
                <span class="text-[10px] text-zinc-700 ml-1.5">{group.words.length}</span>
              </button>
              <button class="idx-checkbox group-checkbox shrink-0" data-group-date={group.id} aria-label={`Select all in ${group.title}`}></button>
            </div>
            <div class="date-group-words">
              {group.words.map(({ w, i }) => (
                <div class="idx-row flex items-center gap-2 pl-8 pr-2 py-1.5 rounded-lg mx-1" data-index={i}>
                  <div class="flex-1 min-w-0 cursor-pointer" data-scroll-to={i}>
                    <div class="flex items-center gap-1.5 flex-wrap">
                      <span class="text-amber-400 text-sm leading-none shrink-0" lang="hi">{w.hindi}</span>
                      <span class="text-teal-300/60 text-[11px] shrink-0">{w.romanisation}</span>
                      <span class="text-slate-200 text-[10px] bg-slate-700/50 px-1.5 py-0.5 rounded-md leading-none shrink-0">{w.english.split(',')[0].trim()}</span>
                    </div>
                  </div>
                  <button class="idx-checkbox word-checkbox shrink-0" data-word-index={i} aria-label={`Select ${w.hindi}`}></button>
                </div>
              ))}
            </div>
          </div>
        ))}
        <p id="words-index-empty" class="hidden px-4 py-6 text-xs text-zinc-600 text-center">No matches</p>
      </nav>

      <!-- Index: sentences (hidden until tab is active) -->
      <nav id="idx-sentences" class="flex-1 overflow-y-auto py-2 hidden">
        {sentences.byDate.map(group => (
          <div class="sentence-group" data-sentence-group={group.date}>
            <div class="date-group-hdr flex items-center gap-1.5 px-2 pt-3 pb-1">
              <button class="collapse-btn shrink-0" aria-label="Collapse group"><span class="chevron">▾</span></button>
              <span class="group-hdr-label font-title text-[10px] font-semibold uppercase tracking-widest text-zinc-500">{group.label}</span>
              <span class="text-[10px] text-zinc-700 ml-1.5">{group.items.length}</span>
            </div>
            <div class="date-group-words">
              {group.items.map(({ w, i }) => (
                <div class="sentence-idx-row idx-row flex items-center gap-2 pl-8 pr-2 py-1.5 rounded-lg mx-1" data-sentence-index={i}>
                  <div class="flex-1 min-w-0 cursor-pointer" data-scroll-to-sentence={i}>
                    <span class="text-amber-400 text-sm leading-none" lang="hi">{(w.hindi as string).slice(0, 40)}{(w.hindi as string).length > 40 ? '…' : ''}</span>
                  </div>
                  <button class="idx-checkbox sentence-checkbox shrink-0" data-sentence-index={i}></button>
                </div>
              ))}
            </div>
          </div>
        ))}
        {allSentences.length === 0 && (
          <p class="px-4 py-6 text-xs text-zinc-600 text-center">No sentences loaded yet.</p>
        )}
        <p id="sentences-index-empty" class="hidden px-4 py-6 text-xs text-zinc-600 text-center">No matches</p>
      </nav>

    </aside>

    <!-- ── Main content ────────────────────────────────────────────────────── -->
    <main class="flex-1 min-w-0 px-5 sm:px-8 py-14 max-w-3xl mx-auto lg:mx-0 lg:max-w-2xl xl:max-w-3xl">

      <!-- Mobile header + search -->
      <div class="lg:hidden mb-10">
        <p class="font-title text-[10px] font-semibold uppercase tracking-[0.2em] text-zinc-600 mb-1">Study companion</p>
        <h1 class="font-title text-3xl font-semibold text-zinc-100 mb-5">Hindi Vocabulary</h1>
        <div class="relative">
          <input
            id="search-mobile"
            type="text"
            autocomplete="off"
            spellcheck="false"
            placeholder="Search words…"
            class="w-full bg-slate-800/60 border border-slate-700/60 rounded-xl pl-4 pr-9 py-2.5 text-sm text-slate-200 placeholder-slate-600 focus:outline-none focus:border-slate-500 transition-colors"
          />
          <button id="search-clear-mobile" class="absolute right-3 top-1/2 -translate-y-1/2 text-zinc-600 hover:text-zinc-300 transition-colors hidden" aria-label="Clear search">✕</button>
        </div>
      </div>

      <!-- ── Mode tab bar ──────────────────────────────────────────────────── -->
      <div class="flex justify-center mb-10">
        <div class="inline-flex bg-slate-800/50 border border-slate-700/40 rounded-full p-1 gap-0.5">
          <button
            id="tab-btn-words"
            class="mode-tab-btn px-6 py-1.5 rounded-full text-sm font-title font-semibold transition-colors bg-slate-700 text-slate-100"
            data-mode="words"
          >
            Words
            <span class="ml-1.5 text-[10px] opacity-60">{allWords.length}</span>
          </button>
          <button
            id="tab-btn-sentences"
            class="mode-tab-btn px-6 py-1.5 rounded-full text-sm font-title font-semibold transition-colors text-slate-500 hover:text-slate-300"
            data-mode="sentences"
          >
            Sentences
            <span class="ml-1.5 text-[10px] opacity-60">{allSentences.length}</span>
          </button>
        </div>
      </div>

      <!-- ── Words section ─────────────────────────────────────────────────── -->
      <div id="words-content">
        <p class="hidden lg:block text-xs text-zinc-600 mb-8 -mt-6" id="words-meta">
          {allWords.length} {allWords.length === 1 ? 'word' : 'words'} &middot; {vocabFiles.length} {vocabFiles.length === 1 ? 'file' : 'files'}
        </p>

        <div class="space-y-5" id="cards-container">
          {allWords.map((word, i) => (
            <div data-word-card={i}>
              <WordCard
                hindi={word.hindi}
                romanisation={word.romanisation}
                english={word.english}
                origin_language={word.origin_language ?? word.origin_tag}
                in_hindi_via={word.in_hindi_via}
                word_category={word.word_category}
                date_added={word.date_added}
                forms={word.forms}
                cross_language_connections={word.cross_language_connections}
                root_breakdown={word.root_breakdown}
                root_parts={word.root_parts}
                root_notes={word.root_notes}
                root_and_origin_explanation={word.root_and_origin_explanation}
                etymology_story={word.etymology_story}
                pronunciation_guide={word.pronunciation_guide}
                memory_hook={word.memory_hook}
                urdu_punjabi={word.urdu_punjabi}
                sound_alikes={word.sound_alikes}
                examples={word.examples}
                index={i}
              />
            </div>
          ))}
        </div>

        <div id="words-no-results" class="hidden py-20 text-center">
          <p class="text-zinc-600 text-sm">No words match your search.</p>
        </div>
      </div>

      <!-- ── Sentences section (hidden until tab active) ───────────────────── -->
      <div id="sentences-content" class="hidden">
        {allSentences.length > 0 ? (
          <div class="space-y-5" id="sentences-container">
            {allSentences.map((sentence, i) => (
              <div data-sentence-card={i}>
                <SentenceCard index={i} {...sentence} />
              </div>
            ))}
          </div>
        ) : (
          <div class="py-24 text-center">
            <p class="text-zinc-600 text-sm mb-2">No sentences loaded yet.</p>
            <p class="text-zinc-700 text-xs">Drop <code class="text-zinc-600">*.json</code> files into <code class="text-zinc-600">sentences/</code> to add sentences.</p>
          </div>
        )}
        <div id="sentences-no-results" class="hidden py-20 text-center">
          <p class="text-zinc-600 text-sm">No sentences match your search.</p>
        </div>
      </div>

      <footer class="mt-20 text-xs text-zinc-700">
        Drop new <code class="text-zinc-600">*.json</code> files into <code class="text-zinc-600">vocab/</code> to add words.
      </footer>
    </main>
  </div>

  <!-- ── Selection bar ──────────────────────────────────────────────────────── -->
  <div
    id="selection-bar"
    class="hidden fixed bottom-0 inset-x-0 z-40 border-t border-slate-700/60 bg-slate-950/95 backdrop-blur px-6 py-3 flex items-center gap-4"
  >
    <span id="sel-count" class="text-sm text-slate-300 mr-auto"></span>
    <button id="sel-all"   class="text-xs text-slate-400 hover:text-slate-100 transition-colors">Show all</button>
    <button id="sel-clear" class="text-xs text-slate-400 hover:text-slate-100 transition-colors">Hide all</button>
    <button id="sel-export" disabled class="text-xs font-semibold px-3 py-1.5 rounded-lg bg-amber-500/20 text-amber-400 border border-amber-500/30 opacity-50 cursor-not-allowed">Export</button>
  </div>

  <!-- ── Hover preview tooltip ──────────────────────────────────────────────── -->
  <div id="word-tooltip" class="fixed z-50 hidden pointer-events-none" style="top:0;left:0;visibility:hidden;">
    <div class="bg-slate-800 border border-slate-700/60 rounded-xl p-3.5 shadow-2xl w-52">
      <p id="tip-hindi"   class="word-hindi font-bold leading-tight mb-1" lang="hi" style="font-family:'Tiro Devanagari Hindi',serif;font-size:1.6rem;"></p>
      <p id="tip-roman"   class="word-roman text-sm mb-1.5"></p>
      <p id="tip-english" class="text-zinc-300 text-[13px] leading-snug"></p>
    </div>
  </div>

</Layout>

<script define:vars={{ wordSearchIndex, sentenceSearchIndex, hoverData }}>
  // ── Helpers ───────────────────────────────────────────────────────────────
  function norm(str) {
    return str.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().trim();
  }

  function fuzzyScore(needle, haystack) {
    needle = norm(needle); haystack = norm(haystack);
    if (!needle) return 0;
    if (haystack.includes(needle)) return 1000;
    let score = 0, hi = 0, streak = 0;
    for (let ni = 0; ni < needle.length; ni++) {
      let found = false;
      while (hi < haystack.length) {
        if (haystack[hi] === needle[ni]) { score += 1 + streak * 2; streak++; hi++; found = true; break; }
        streak = 0; hi++;
      }
      if (!found) return -1;
    }
    return score;
  }

  function bestScore(needle, entry) {
    return Math.max(fuzzyScore(needle, entry.e), fuzzyScore(needle, entry.r), fuzzyScore(needle, entry.h));
  }

  // ── Mode state ────────────────────────────────────────────────────────────
  let currentMode = 'words'; // 'words' | 'sentences'

  // ── DOM refs ──────────────────────────────────────────────────────────────
  const inputs      = [document.getElementById('search'), document.getElementById('search-mobile')].filter(Boolean);
  const clearBtns   = [document.getElementById('search-clear'), document.getElementById('search-clear-mobile')].filter(Boolean);
  const searchCount = document.getElementById('search-count');

  const wordCards     = document.querySelectorAll('[data-word-card]');
  const sentenceCards = document.querySelectorAll('[data-sentence-card]');

  const idxWords     = document.getElementById('idx-words');
  const idxSentences = document.getElementById('idx-sentences');

  // Cache index rows by data index
  const wordRowMap     = {};
  const sentenceRowMap = {};
  document.querySelectorAll('#idx-words .idx-row[data-index]').forEach(el => {
    wordRowMap[parseInt(el.dataset.index)] = el;
  });
  document.querySelectorAll('#idx-sentences .idx-row[data-sentence-index]').forEach(el => {
    sentenceRowMap[parseInt(el.dataset.sentenceIndex)] = el;
  });

  // ── Selection state ───────────────────────────────────────────────────────
  const selectedWords     = new Set(wordSearchIndex.map(w => w.i));
  const selectedSentences = new Set(sentenceSearchIndex.map(s => s.i));

  const selectionBar = document.getElementById('selection-bar');
  const selCount     = document.getElementById('sel-count');

  // Mark all word checkboxes / rows as selected on load
  document.querySelectorAll('#idx-words .word-checkbox').forEach(cb => cb.classList.add('is-on'));
  document.querySelectorAll('#idx-words .idx-row').forEach(r => r.classList.add('is-sel'));
  document.querySelectorAll('#idx-words .group-checkbox').forEach(cb => cb.classList.add('is-on'));

  function refreshSelectionBar() {
    const index  = currentMode === 'words' ? wordSearchIndex : sentenceSearchIndex;
    const selSet = currentMode === 'words' ? selectedWords   : selectedSentences;
    const total  = index.length;
    const n      = selSet.size;
    const hidden = total - n;
    selectionBar.classList.toggle('hidden', hidden === 0);
    if (selCount) selCount.textContent = `${hidden} hidden · ${n} of ${total} shown`;
  }

  function setWordSelected(idx, on) {
    if (on) selectedWords.add(idx); else selectedWords.delete(idx);
    document.querySelector(`#idx-words .word-checkbox[data-word-index="${idx}"]`)?.classList.toggle('is-on', on);
    wordRowMap[idx]?.classList.toggle('is-sel', on);
    refreshSelectionBar();
  }

  function setSentenceSelected(idx, on) {
    if (on) selectedSentences.add(idx); else selectedSentences.delete(idx);
    document.querySelector(`#idx-sentences .sentence-checkbox[data-sentence-index="${idx}"]`)?.classList.toggle('is-on', on);
    sentenceRowMap[idx]?.classList.toggle('is-sel', on);
    refreshSelectionBar();
  }

  function setSelected(idx, on) {
    if (currentMode === 'words') setWordSelected(idx, on);
    else setSentenceSelected(idx, on);
  }

  function syncGroupCheckbox(groupDate) {
    const groupEl = document.querySelector(`#idx-words .date-group[data-group="${groupDate}"]`);
    if (!groupEl) return;
    const rows = [...groupEl.querySelectorAll('.idx-row[data-index]')];
    const cb   = groupEl.querySelector('.group-checkbox');
    if (!cb || rows.length === 0) return;
    cb.classList.toggle('is-on', rows.every(r => selectedWords.has(parseInt(r.dataset.index))));
  }

  // ── Core filter ───────────────────────────────────────────────────────────
  function applyFilter() {
    const q = (inputs[0]?.value ?? '').trim();
    clearBtns.forEach(btn => btn.classList.toggle('hidden', q.length === 0));

    if (currentMode === 'words') {
      let searchMatches = 0, cardsVisible = 0;
      wordSearchIndex.forEach(word => {
        const searchOk = !q || bestScore(q, word) >= 0;
        const selOk    = selectedWords.has(word.i);
        wordCards[word.i]?.classList.toggle('hidden', !(searchOk && selOk));
        wordRowMap[word.i]?.classList.toggle('hidden', !searchOk);
        if (searchOk) searchMatches++;
        if (searchOk && selOk) cardsVisible++;
      });
      document.querySelectorAll('#idx-words .date-group').forEach(group => {
        const any = [...group.querySelectorAll('.idx-row')].some(r => !r.classList.contains('hidden'));
        group.classList.toggle('hidden', !any);
      });
      if (searchCount) searchCount.textContent = q
        ? `${searchMatches} of ${wordSearchIndex.length} words`
        : `${wordSearchIndex.length} words`;
      document.getElementById('words-index-empty')?.classList.toggle('hidden', searchMatches > 0);
      document.getElementById('words-no-results')?.classList.toggle('hidden', cardsVisible > 0);

    } else {
      let searchMatches = 0, cardsVisible = 0;
      sentenceSearchIndex.forEach(s => {
        const searchOk = !q || bestScore(q, s) >= 0;
        const selOk    = selectedSentences.has(s.i);
        sentenceCards[s.i]?.classList.toggle('hidden', !(searchOk && selOk));
        sentenceRowMap[s.i]?.classList.toggle('hidden', !searchOk);
        if (searchOk) searchMatches++;
        if (searchOk && selOk) cardsVisible++;
      });
      document.querySelectorAll('#idx-sentences .sentence-group').forEach(group => {
        const any = [...group.querySelectorAll('.idx-row')].some(r => !r.classList.contains('hidden'));
        group.classList.toggle('hidden', !any);
      });
      if (searchCount) searchCount.textContent = q
        ? `${searchMatches} of ${sentenceSearchIndex.length} sentences`
        : `${sentenceSearchIndex.length} sentences`;
      document.getElementById('sentences-index-empty')?.classList.toggle('hidden', searchMatches > 0);
      document.getElementById('sentences-no-results')?.classList.toggle('hidden', cardsVisible > 0);
    }

    refreshSelectionBar();
  }

  // ── Mode switching ────────────────────────────────────────────────────────
  function switchMode(mode) {
    currentMode = mode;

    // Tab button styles
    document.querySelectorAll('.mode-tab-btn').forEach(btn => {
      const isActive = btn.dataset.mode === mode;
      btn.classList.toggle('bg-slate-700', isActive);
      btn.classList.toggle('text-slate-100', isActive);
      btn.classList.toggle('text-slate-500', !isActive);
    });

    // Content panels
    document.getElementById('words-content')?.classList.toggle('hidden', mode !== 'words');
    document.getElementById('sentences-content')?.classList.toggle('hidden', mode !== 'sentences');

    // Sidebar index panels
    idxWords?.classList.toggle('hidden', mode !== 'words');
    idxSentences?.classList.toggle('hidden', mode !== 'sentences');

    // Search placeholder
    const placeholder = mode === 'words' ? 'Search words…' : 'Search sentences…';
    inputs.forEach(inp => inp.placeholder = placeholder);

    applyFilter();
  }

  document.querySelectorAll('.mode-tab-btn').forEach(btn => {
    btn.addEventListener('click', () => switchMode(btn.dataset.mode));
  });

  // ── Search inputs ─────────────────────────────────────────────────────────
  inputs.forEach(input => {
    input.addEventListener('input', () => {
      inputs.forEach(other => { if (other !== input) other.value = input.value; });
      applyFilter();
    });
  });
  clearBtns.forEach((btn, i) => {
    btn.addEventListener('click', () => {
      inputs.forEach(inp => inp.value = '');
      applyFilter();
      inputs[i]?.focus();
    });
  });

  // ── Click + drag on word checkboxes ──────────────────────────────────────
  let isDragging = false;
  let dragMode   = true;

  idxWords?.addEventListener('mousedown', (e) => {
    const cb = e.target.closest('.word-checkbox');
    if (!cb) return;
    e.preventDefault();
    const idx = parseInt(cb.dataset.wordIndex);
    dragMode = !selectedWords.has(idx);
    setWordSelected(idx, dragMode);
    isDragging = true;
    syncGroupCheckbox(cb.closest('.date-group')?.dataset.group ?? '');
    applyFilter();
  });

  idxWords?.addEventListener('mouseover', (e) => {
    if (!isDragging) return;
    const cb = e.target.closest('.word-checkbox');
    if (!cb) return;
    const idx = parseInt(cb.dataset.wordIndex);
    if (selectedWords.has(idx) === dragMode) return;
    setWordSelected(idx, dragMode);
    syncGroupCheckbox(cb.closest('.date-group')?.dataset.group ?? '');
    applyFilter();
  });

  document.addEventListener('mouseup', () => { isDragging = false; });

  // ── Index click events ────────────────────────────────────────────────────
  idxWords?.addEventListener('click', (e) => {
    if (e.target.closest('.word-checkbox')) return;

    const gCb = e.target.closest('.group-checkbox');
    if (gCb) {
      const gDate   = gCb.dataset.groupDate;
      const groupEl = document.querySelector(`#idx-words .date-group[data-group="${gDate}"]`);
      if (!groupEl) return;
      const rows  = [...groupEl.querySelectorAll('.idx-row[data-index]')];
      const allOn = rows.every(r => selectedWords.has(parseInt(r.dataset.index)));
      rows.forEach(r => setWordSelected(parseInt(r.dataset.index), !allOn));
      syncGroupCheckbox(gDate);
      applyFilter();
      return;
    }

    const collapseBtn = e.target.closest('.collapse-btn');
    if (collapseBtn) {
      const groupEl = collapseBtn.closest('.date-group');
      groupEl?.querySelector('.date-group-words')?.classList.toggle('collapsed');
      collapseBtn.classList.toggle('is-collapsed');
      return;
    }

    const toggleBtn = e.target.closest('.date-group-toggle');
    if (toggleBtn) {
      const groupEl = toggleBtn.closest('.date-group');
      groupEl?.querySelector('.date-group-words')?.classList.toggle('collapsed');
      groupEl?.querySelector('.collapse-btn')?.classList.toggle('is-collapsed');
      return;
    }

    const scrollEl = e.target.closest('[data-scroll-to]');
    if (scrollEl) {
      document.getElementById(`card-${scrollEl.dataset.scrollTo}`)
        ?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });

  // ── Card collapse / deselect buttons ─────────────────────────────────────
  document.getElementById('cards-container')?.addEventListener('click', (e) => {
    const header = e.target.closest('.card-header');
    if (header && !e.target.closest('.deselect-btn')) {
      header.closest('article')?.classList.toggle('is-collapsed');
      return;
    }
    const btn = e.target.closest('.deselect-btn');
    if (!btn) return;
    const idx = parseInt(btn.dataset.deselectIndex);
    setWordSelected(idx, false);
    syncGroupCheckbox(wordRowMap[idx]?.closest('.date-group')?.dataset.group ?? '');
    applyFilter();
  });

  // ── Selection bar buttons ─────────────────────────────────────────────────
  document.getElementById('sel-all')?.addEventListener('click', () => {
    const index = currentMode === 'words' ? wordSearchIndex : sentenceSearchIndex;
    index.forEach(entry => setSelected(entry.i, true));
    if (currentMode === 'words') {
      document.querySelectorAll('#idx-words .date-group[data-group]').forEach(g => syncGroupCheckbox(g.dataset.group));
    }
    applyFilter();
  });

  document.getElementById('sel-clear')?.addEventListener('click', () => {
    const selSet = currentMode === 'words' ? selectedWords : selectedSentences;
    [...selSet].forEach(idx => setSelected(idx, false));
    if (currentMode === 'words') {
      document.querySelectorAll('#idx-words .group-checkbox').forEach(cb => cb.classList.remove('is-on'));
    }
    applyFilter();
  });

  // ── Active card highlight in sidebar ─────────────────────────────────────
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const idx = entry.target.dataset.cardIndex;
      document.querySelectorAll('#idx-words .idx-row').forEach(r => r.classList.remove('is-active'));
      const row = wordRowMap[idx];
      row?.classList.add('is-active');
      row?.scrollIntoView({ block: 'nearest' });
    });
  }, { threshold: 0.4 });

  wordCards.forEach((el, i) => {
    const article = el.querySelector('article');
    if (article) article.dataset.cardIndex = String(i);
    observer.observe(el);
  });

  // ── Vocab hover preview ───────────────────────────────────────────────────
  const hindiMap = {};
  const romanMap = {};
  hoverData.forEach(word => {
    hindiMap[word.hindi] = word;
    romanMap[norm(word.roman)] = word;
    (word.forms || []).forEach(f => {
      if (f.h) hindiMap[f.h] = word;
      if (f.r) romanMap[norm(f.r)] = word;
    });
  });

  function escAttr(str) {
    return String(str).replace(/&/g, '&amp;').replace(/"/g, '&quot;');
  }

  function annotateHindi(text, excludeSet) {
    return text.replace(/[\u0900-\u097F]+/g, word => {
      if (excludeSet.has(word)) return word;
      const d = hindiMap[word];
      if (!d) return word;
      return `<span class="vocab-hint" data-h="${escAttr(d.hindi)}" data-r="${escAttr(d.roman)}" data-e="${escAttr(d.english)}">${word}</span>`;
    });
  }

  function annotateRoman(text, excludeSet) {
    return text.replace(/[a-zA-Zāīūṭḍṇśṣṃḥṛṝḷ]+/g, word => {
      const key = norm(word);
      if (excludeSet.has(key)) return word;
      const d = romanMap[key];
      if (!d) return word;
      return `<span class="vocab-hint" data-h="${escAttr(d.hindi)}" data-r="${escAttr(d.roman)}" data-e="${escAttr(d.english)}">${word}</span>`;
    });
  }

  document.querySelectorAll('[data-example-card]').forEach(container => {
    const cardIdx = parseInt(container.dataset.exampleCard);
    const cw = hoverData[cardIdx];
    if (!cw) return;
    const excludeHindi = new Set([cw.hindi, ...(cw.forms || []).map(f => f.h)]);
    const excludeRoman = new Set([norm(cw.roman), ...(cw.forms || []).map(f => norm(f.r))]);
    const hindiP = container.querySelector('[lang="hi"]');
    if (hindiP) { const orig = hindiP.textContent; const ann = annotateHindi(orig, excludeHindi); if (ann !== orig) hindiP.innerHTML = ann; }
    const romanP = container.querySelector('p.word-roman');
    if (romanP) { const orig = romanP.textContent; const ann = annotateRoman(orig, excludeRoman); if (ann !== orig) romanP.innerHTML = ann; }
  });

  // ── Tooltip ───────────────────────────────────────────────────────────────
  const tooltip    = document.getElementById('word-tooltip');
  const tipHindi   = document.getElementById('tip-hindi');
  const tipRoman   = document.getElementById('tip-roman');
  const tipEnglish = document.getElementById('tip-english');

  document.addEventListener('mouseover', e => {
    const hint = e.target.closest('.vocab-hint');
    if (!hint) { tooltip.classList.add('hidden'); tooltip.style.visibility = 'hidden'; return; }
    tipHindi.textContent   = hint.dataset.h;
    tipRoman.textContent   = hint.dataset.r;
    tipEnglish.textContent = hint.dataset.e;
    tooltip.style.visibility = 'hidden';
    tooltip.classList.remove('hidden');
    requestAnimationFrame(() => {
      const hr = hint.getBoundingClientRect();
      const tr = tooltip.getBoundingClientRect();
      let top  = hr.top - tr.height - 10;
      let left = hr.left + hr.width / 2 - tr.width / 2;
      if (top < 8) top = hr.bottom + 10;
      left = Math.max(8, Math.min(left, window.innerWidth - tr.width - 8));
      tooltip.style.top        = `${top}px`;
      tooltip.style.left       = `${left}px`;
      tooltip.style.visibility = 'visible';
    });
  });
</script>
