---
// Responsible for: page entry point — loads vocab data, passes it to components, renders app shell
import Layout      from '../layouts/Layout.astro';
import AppSidebar  from '../components/sidebar/AppSidebar.astro';
import WordsTab    from '../components/tabs/WordsTab.astro';
import SentencesTab from '../components/tabs/SentencesTab.astro';
import ExportTab   from '../components/tabs/ExportTab.astro';
import TabBar      from '../components/ui/TabBar.astro';
import MobileHeader from '../components/MobileHeader.astro';
import { readdir, readFile } from 'node:fs/promises';
import { join } from 'node:path';

// ── Load words ────────────────────────────────────────────────────────────────
const vocabDir   = join(process.cwd(), 'vocab');
const vocabFiles = (await readdir(vocabDir)).filter(f => f.endsWith('.json')).sort();

const allFiles = await Promise.all(
  vocabFiles.map(async (f) => {
    const data  = JSON.parse(await readFile(join(vocabDir, f), 'utf-8'));
    const title = (typeof data === 'object' && !Array.isArray(data) && data.title)
      ? data.title : f.replace('.json', '').replace(/_/g, ' ');
    const words = Array.isArray(data) ? data : (data.words ?? []);
    return { title, words };
  })
);
const allWords = allFiles.flatMap(f => f.words);

const wordGroups = (() => {
  let offset = 0;
  return allFiles.filter(f => f.words.length > 0).map((file, fi) => {
    const group = { id: String(fi), title: file.title,
      words: file.words.map((w: any, li: number) => ({ w, i: offset + li })) };
    offset += file.words.length;
    return group;
  });
})();

// ── Load sentences (graceful — dir may not exist yet) ─────────────────────────
let allSentences: any[] = [];
try {
  const sentDir   = join(process.cwd(), 'sentences');
  const sentFiles = (await readdir(sentDir)).filter(f => f.endsWith('.json')).sort();
  allSentences = (await Promise.all(sentFiles.map(async f => JSON.parse(await readFile(join(sentDir, f), 'utf-8'))))).flat();
} catch { /* sentences/ dir doesn't exist yet */ }

// ── Group sentences by date ───────────────────────────────────────────────────
function fmtDate(iso: string): string {
  const m = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const [y, mo, d] = iso.split('-');
  return `${m[parseInt(mo) - 1]} ${parseInt(d)}, ${y}`;
}
const sentDateSet = [...new Set(allSentences.map(w => w.date_added).filter(Boolean) as string[])].sort((a, b) => b.localeCompare(a));
const sentencesByDate = sentDateSet.map(date => ({
  date, label: fmtDate(date),
  items: allSentences.map((w, i) => ({ w, i })).filter(({ w }) => (w.date_added ?? '') === date),
}));

// ── Client-side search + hover payloads ──────────────────────────────────────
const wordSearchIndex     = allWords.map((w, i) => ({ i, h: w.hindi, r: w.romanisation, e: w.english, d: w.date_added ?? '' }));
const sentenceSearchIndex = allSentences.map((s, i) => ({ i, h: s.hindi ?? '', r: s.romanisation ?? '', e: s.english ?? '', d: s.date_added ?? '' }));
const hoverData           = allWords.map((w, i) => ({
  i, hindi: w.hindi, roman: w.romanisation,
  english: (w.english as string).split(',')[0].trim(),
  forms: (w.forms || []).map((f: { hindi: string; roman: string }) => ({ h: f.hindi, r: f.roman })),
}));
const wordGroupTitles: string[] = new Array(allWords.length).fill('Hindi Vocabulary');
wordGroups.forEach(g => g.words.forEach(({ i }) => { wordGroupTitles[i] = g.title; }));
---

<Layout title="Hindi Vocabulary">
  <div class="lg:flex min-h-screen pb-14">

    <AppSidebar wordGroups={wordGroups} totalWords={allWords.length} sentencesByDate={sentencesByDate} totalSentences={allSentences.length} />

    <main class="flex-1 min-w-0">
      <MobileHeader />
      <WordsTab allWords={allWords} vocabFilesCount={vocabFiles.length} />
      <SentencesTab allSentences={allSentences} sentencesByDate={sentencesByDate} />
      <ExportTab />
    </main>
  </div>

  <!-- Hover tooltip -->
  <div id="word-tooltip" class="fixed z-50 hidden pointer-events-none" style="top:0;left:0;visibility:hidden;">
    <div class="bg-slate-800 border border-slate-700/60 rounded-xl p-3.5 shadow-2xl w-52">
      <p id="tip-hindi"   class="word-hindi font-bold leading-tight mb-1" lang="hi" style="font-family:'Tiro Devanagari Hindi',serif;font-size:1.6rem;"></p>
      <p id="tip-roman"   class="word-roman text-sm mb-1.5"></p>
      <p id="tip-english" class="text-zinc-300 text-[13px] leading-snug"></p>
    </div>
  </div>

  <TabBar />
</Layout>

<script define:vars={{ __d: { allWords, wordGroupTitles, wordSearchIndex, sentenceSearchIndex, hoverData } }}>
  window.__APP_DATA__ = __d;
</script>
<script>
  import '../scripts/main.js';
</script>
