---
// Responsible for: page entry point — loads vocab data, passes it to components, renders app shell
import Layout      from '../layouts/Layout.astro';
import NavBar      from '../components/NavBar.astro';
import WordsTab    from '../components/tabs/WordsTab.astro';
import SentencesTab from '../components/tabs/SentencesTab.astro';
import ExportTab   from '../components/tabs/ExportTab.astro';
import { readdir, readFile } from 'node:fs/promises';
import { join } from 'node:path';

// ── Load words ────────────────────────────────────────────────────────────────
const vocabDir   = join(process.cwd(), 'vocab', 'words');
const vocabFiles = (await readdir(vocabDir)).filter(f => f.endsWith('.json')).sort();

const allFiles = await Promise.all(
  vocabFiles.map(async (f) => {
    const audioBatch = f.replace('.json', '');
    const data  = JSON.parse(await readFile(join(vocabDir, f), 'utf-8'));
    const title = (typeof data === 'object' && !Array.isArray(data))
      ? (data.chapter ?? data.title ?? f.replace('.json', '').replace(/_/g, ' '))
      : f.replace('.json', '').replace(/_/g, ' ');
    const rawWords = Array.isArray(data) ? data : (data.words ?? []);
    // Stamp each word with its audioBatch so components can resolve audio paths
    const words = rawWords.map((w: any) => ({ ...w, audioBatch }));
    return { title, words };
  })
);
const allWords = allFiles.flatMap(f => f.words);

const wordGroups = (() => {
  let offset = 0;
  const merged = new Map<string, { id: string; title: string; words: { w: any; i: number }[] }>();
  let groupIndex = 0;

  for (const file of allFiles.filter(f => f.words.length > 0)) {
    if (!merged.has(file.title)) {
      merged.set(file.title, { id: String(groupIndex++), title: file.title, words: [] });
    }
    const group = merged.get(file.title)!;
    for (const w of file.words) {
      group.words.push({ w, i: offset++ });
    }
  }

  return [...merged.values()];
})();

// ── Load sentences (graceful — dir may not exist yet) ─────────────────────────
let allSentences: any[] = [];
let sentenceChapters: { chapter: string; sentences: any[] }[] = [];
try {
  const sentDir   = join(process.cwd(), 'vocab', 'sentences');
  const sentFiles = (await readdir(sentDir)).filter(f => f.endsWith('.json')).sort();
  const rawSentenceFiles = await Promise.all(
    sentFiles.map(async f => ({ audioBatch: f.replace('.json', ''), data: JSON.parse(await readFile(join(sentDir, f), 'utf-8')) }))
  );
  // Each file is { chapter, sentences[] }
  sentenceChapters = rawSentenceFiles.map(({ audioBatch, data }) => {
    const chapter = (typeof data === 'object' && !Array.isArray(data) && data.sentences)
      ? data.chapter ?? ''
      : '';
    const rawSentences = (typeof data === 'object' && !Array.isArray(data) && data.sentences)
      ? data.sentences
      : Array.isArray(data) ? data : [];
    // Stamp each sentence with its audioBatch
    const sentences = rawSentences.map((s: any) => ({ ...s, audioBatch }));
    return { chapter, sentences };
  });
  allSentences = sentenceChapters.flatMap(c => c.sentences);
} catch { /* vocab/sentences/ dir doesn't exist yet */ }

// Build a parallel array mapping sentence index → chapter name for search filtering
const sentenceChapterNames: string[] = sentenceChapters.flatMap(c =>
  c.sentences.map(() => c.chapter)
);

// ── Client-side search + hover payloads ──────────────────────────────────────
const wordSearchIndex     = allWords.map((w, i) => ({ i, h: w.hindi, r: w.romanisation, e: w.english, d: w.date_added ?? '' }));
const sentenceSearchIndex = allSentences.map((s, i) => ({ i, h: s.hindi ?? '', r: s.romanisation ?? '', e: s.english ?? '', d: s.date_added ?? '', ch: sentenceChapterNames[i] ?? '' }));
const hoverData           = allWords.map((w, i) => ({
  i, hindi: w.hindi, roman: w.romanisation,
  english: (w.english as string).split(',')[0].trim(),
  forms: (w.forms || []).map((f: { hindi: string; roman: string }) => ({ h: f.hindi, r: f.roman })),
}));
const wordGroupTitles: string[] = new Array(allWords.length).fill('Hindi Vocabulary');
wordGroups.forEach(g => g.words.forEach(({ i }) => { wordGroupTitles[i] = g.title; }));
---

<Layout title="Hindi Vocabulary">

  <!-- Single-column app shell: sticky nav + centred page content -->
  <div class="app-shell">

    <NavBar />

    <main class="page-content" id="page-content">

      <WordsTab allWords={allWords} vocabFilesCount={vocabFiles.length} wordGroups={wordGroups} />
      <SentencesTab allSentences={allSentences} sentenceChapters={sentenceChapters} />
      <ExportTab />

    </main>

  </div>

  <!-- Hover tooltip -->
  <div id="word-tooltip" class="fixed z-50 hidden pointer-events-none" style="top:0;left:0;visibility:hidden;">
    <div class="bg-slate-800 border border-slate-700/60 rounded-xl p-3.5 shadow-2xl w-52">
      <p id="tip-hindi"   class="word-hindi font-bold leading-tight mb-1" lang="hi" style="font-family:'Tiro Devanagari Hindi',serif;font-size:1.6rem;"></p>
      <p id="tip-roman"   class="word-roman text-sm mb-1.5"></p>
      <p id="tip-english" class="text-zinc-300 text-[13px] leading-snug"></p>
    </div>
  </div>

<script define:vars={{ __d: { allWords, wordGroupTitles, wordSearchIndex, sentenceSearchIndex, hoverData, allSentences } }}>
  window.__APP_DATA__ = __d;
</script>
<script>
  import '../scripts/main.js';
</script>
</Layout>
